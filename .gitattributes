# flake.lock is fully generated by `nix flake update`, so there is never any
# value in a hand-resolved merge. Route it through the `flakelock` merge
# driver (registered in .git/config by `hm update`/`upgrade`) which always
# keeps the in-progress side, turning every rebase/pull into a no-conflict
# operation. `hm` then re-runs `nix flake update` to land the newest revs.
flake.lock merge=flakelock
