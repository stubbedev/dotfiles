function _phpstorm_remote_dev_bin {
  local _candidates=(
    "$HOME/.local/share/JetBrains/Toolbox/apps/phpstorm/bin/remote-dev-server.sh"
    "$HOME/.local/share/JetBrains/Toolbox/apps/PhpStorm/bin/remote-dev-server.sh"
    "/opt/phpstorm/bin/remote-dev-server.sh"
  )
  local _c
  for _c in "${_candidates[@]}"; do
    [[ -x "$_c" ]] && { echo "$_c"; return 0; }
  done
  return 1
}

if _phpstorm_remote_dev_bin >/dev/null; then
  function phpstorm_headless {
    local _project=$(realpath "${1:-$PWD}" 2>/dev/null)
    if [[ -z "$_project" || ! -d "$_project" ]]; then
      echo "phpstorm_headless: not a directory: ${1:-$PWD}" >&2
      return 1
    fi
    if pgrep -af "remote-dev-server.*${_project}( |$)" >/dev/null 2>&1; then
      echo "phpstorm_headless: already running for $_project"
      return 0
    fi
    local _bin=$(_phpstorm_remote_dev_bin)
    local _log="${TMPDIR:-/tmp}/phpstorm-headless-${_project//\//_}.log"
    nohup "$_bin" run "$_project" >"$_log" 2>&1 &!
    echo "phpstorm_headless: started for $_project (log: $_log)"
  }
fi

