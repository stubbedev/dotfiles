#!/usr/bin/env zsh
# shellcheck disable=SC1091

typeset -gA _git_shorthand_docs=(
  gcm 'git commit with auto ticket prefix; trailing \ opens editor; explicit ABC-1234: prefix overrides'
  gp 'git push (warns on protected branches, release/*, hotfix/*, gp.protected patterns, upstream-ahead)'
  gcb 'checkout or create branch (feature/bugfix/hotfix prefixes)'
  ga 'interactively stage files (single panel, M/A/D markers, type-aware action)'
  gsd 'show working tree diff'
  gd 'three-dot diff: changes on another branch since fork point with current'
  gcd 'export three-dot branch diff to a patch file'
  gst 'git status (short format)'
  gg 'git pull current branch from origin (--all for all branches)'
  gf 'git fetch (--all for all remotes)'
  gsa 'stash all local changes'
  gcs 'clear the entire stash stack (with confirmation)'
  gw 'wipe local changes (stash + drop; --all drops the entire stash stack)'
  ggo 'pull from a selected origin branch'
  gl 'interactive git log (multi-select; ctrl-y copy hash, ctrl-x cherry-pick, ctrl-r revert)'
  gsp 'interactive stash pop (fzf select from stash list)'
  gwt 'switch to or create git worktree (name w/o slash → wizard, Ctrl+C → wizard escape hatch; -c/-s/-p flags = non-interactive)'
  gwtd 'remove a git worktree'
  gwte 'cd to main repo root (exit linked worktree); does not remove the worktree'
  gwtc 'cd to main repo root and remove the linked worktree we just exited (skips if dirty/unpushed)'
)

# Walk up directory tree looking for .git (handles regular repos and worktrees).
# Sets _git_root to the repo/worktree root. No git fork needed.
function in_git_repo {
  local dir=$PWD
  while [[ $dir != / ]]; do
    if [[ -e $dir/.git ]]; then
      _git_root=$dir
      return 0
    fi
    dir=${dir:h}
  done
  return 1
}

# In a linked worktree, $_git_root/.git is a file (gitlink). In the main repo
# it's a directory. Requires _git_root to be set (call in_git_repo first).
function _in_linked_worktree {
  [[ -f "$_git_root/.git" ]]
}

# Path of the main repo root, regardless of which worktree we're in.
function _git_main_root {
  local _common=$(git rev-parse --git-common-dir 2>/dev/null)
  [[ -z "$_common" ]] && return 1
  [[ "$_common" != /* ]] && _common="$(cd "$_common" && pwd -P)"
  if [[ "$_common" == */.git ]]; then
    echo "${_common%/.git}"
  else
    echo "$_common"
  fi
}

# Remove the previous worktree if we've moved out of it. Caller must have
# already verified it was clean before the switch. Skipped if the worktree
# has commits that aren't on its upstream — those would be silently lost.
# Delegates teardown to `treeman wt delete` (runs predelete hooks + DB
# scoping cleanup + git worktree remove).
function _gwt_remove_if_clean {
  local _prev="$1"
  [[ -z "$_prev" ]] && return 0
  [[ "$PWD" == "$_prev" || "$PWD" == "$_prev"/* ]] && return 0
  local _main=$(_git_main_root 2>/dev/null) || _main=""
  [[ -z "$_main" || "$PWD" != "$_main" ]] && return 0
  if _worktree_has_unpushed "$_prev"; then
    echo "gwt: keeping $_prev (has unpushed commits)"
    return 0
  fi
  ( treeman wt delete "$_prev" --yes --force --repo "$_main" >/dev/null 2>&1 ) &!
}

# Emit one "<path>\t<branch>" line per linked worktree on a branch.
# Worktrees in detached HEAD or bare are skipped (no `branch` line).
function _list_worktrees {
  local _wt_path="" _wt_branch="" _wt_line
  while IFS= read -r _wt_line; do
    if [[ $_wt_line == worktree\ * ]]; then
      _wt_path=${_wt_line#worktree }
      _wt_branch=""
    elif [[ $_wt_line == branch\ * ]]; then
      _wt_branch=${_wt_line#branch refs/heads/}
    elif [[ -z $_wt_line ]]; then
      [[ -n $_wt_branch && -n $_wt_path ]] && printf '%s\t%s\n' "$_wt_path" "$_wt_branch"
      _wt_path="" _wt_branch=""
    fi
  done < <(
    git worktree list --porcelain 2>/dev/null
    echo
  )
}

# Print the path of the worktree that has $1 checked out, or nothing if none.
# Tries `treeman wt go` first (registry lookup, sub-ms); on any
# treeman failure — old binary missing the subcommand, repo not yet
# registered, no match — falls through to the porcelain parser so the
# function stays correct against non-treeman repos too. The treeman path
# emits stderr on miss; silence it to keep parity with the old silent
# return-1 contract.
function _worktree_path_for_branch {
  local _target="$1" _path _branch
  if (( $+commands[treeman] )); then
    local _main=$(_git_main_root 2>/dev/null) || _main=""
    if [[ -n "$_main" ]]; then
      local _p
      _p=$(treeman wt go "$_target" --repo "$_main" 2>/dev/null)
      [[ -n "$_p" ]] && { echo "$_p"; return 0; }
    fi
  fi
  while IFS=$'\t' read -r _path _branch; do
    [[ "$_branch" == "$_target" ]] && { echo "$_path"; return 0; }
  done < <(_list_worktrees)
  return 1
}

# Switch to or create a branch with worktree-aware routing.
# Args: $1 branch, $2 mode ("checkout" default | "create"), $3 base for create
# Strategy:
#   1. Branch already in another worktree → cd there
#   2. In a linked worktree and main repo clean → cd to main, checkout/create there
#   3. In a linked worktree and main dirty → create a new worktree for the branch
#   4. Otherwise → checkout/create in place
# Requires _git_root to be set (call in_git_repo first).
function _checkout_branch_or_worktree {
  local _target="$1" _mode="${2:-checkout}" _base="$3"
  [[ -z "$_target" ]] && return 1

  local _existing_wt=$(_worktree_path_for_branch "$_target")
  if [[ -n "$_existing_wt" && "$_existing_wt" != "$_git_root" ]]; then
    cd "$_existing_wt" || return 1
    echo "Switched to worktree: $_existing_wt"
    return 0
  fi

  # If asked to create but branch exists locally, fall back to checkout
  if [[ "$_mode" == "create" ]] && git rev-parse --verify --quiet "refs/heads/$_target" >/dev/null 2>&1; then
    _mode="checkout"
    _base=""
  fi

  # Direct-checkout paths (lines below) need the resolved origin/$_base so a
  # stale local ref doesn't silently base the new branch on yesterday's commit.
  # Worktree-routing paths pass the unresolved $_base to _gwt_create, which
  # runs _resolve_base itself — don't double-resolve there.
  local -a _action
  if [[ "$_mode" == "create" ]]; then
    if [[ -n "$_base" ]]; then
      local _resolved_base=$(_resolve_base "$_base")
      _action=(git checkout -b "$_target" "$_resolved_base")
    else
      _action=(git checkout -b "$_target")
    fi
  else
    _action=(git checkout "$_target")
  fi

  if ! _in_linked_worktree; then
    "${_action[@]}"
    return $?
  fi

  local _main=$(_git_main_root)
  if [[ -z "$(git -C "$_main" status --porcelain 2>/dev/null)" ]]; then
    cd "$_main" || return 1
    "${_action[@]}"
    return $?
  fi

  if [[ "$_mode" == "create" ]]; then
    _gwt_create "$_target" "$_base"
  else
    _gwt_attach "$_target"
  fi
}

# Strip leading/trailing whitespace from a string.
function _trim_ws {
  local v="$1"
  v="${v#"${v%%[![:space:]]*}"}"
  v="${v%"${v##*[![:space:]]}"}"
  print -r -- "$v"
}

# Fork-free branch listing: sets $reply to sorted-unique branch array.
# Uses %(refname) to avoid parsing git's marker/color output entirely.
function _list_git_branches {
  local -a _arr=()
  local _b
  while IFS= read -r _b; do
    if [[ $_b == refs/heads/* ]]; then
      _arr+=("${_b#refs/heads/}")
    elif [[ $_b == refs/remotes/origin/* ]]; then
      local _rb=${_b#refs/remotes/origin/}
      [[ $_rb == HEAD ]] && continue
      _arr+=("$_rb")
    fi
  done < <(git branch --all --format='%(refname)' 2>/dev/null)
  reply=(${(ou)_arr})
}

# Resolve repo default branch via origin/HEAD, falling back to master/main.
# Echoes the branch name; returns 1 if it can't be determined.
function _default_branch {
  local _default=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null)
  _default=${_default#refs/remotes/origin/}
  if [[ -z "$_default" ]]; then
    local _b
    for _b in master main; do
      if git rev-parse --verify --quiet "refs/heads/$_b" >/dev/null 2>&1; then
        _default=$_b
        break
      fi
    done
  fi
  [[ -z "$_default" ]] && return 1
  echo "$_default"
}

# Prompt for a base branch via fzf. Echoes selection; returns 1 if cancelled.
function _pick_base_branch {
  local _prompt="${1:-(Enter: select base branch)> }"
  _list_git_branches
  local _branches=${(F)reply}
  local _picked=$(echo "$_branches" |
    fzf --prompt="$_prompt" \
      --no-info \
      --height=~4)
  [[ -z "$_picked" ]] && return 1
  echo "$_picked"
}

# True if the worktree at $1 has any uncommitted changes.
function _worktree_is_dirty {
  local _p="$1"
  [[ -z "$_p" ]] && return 1
  [[ -n "$(git -C "$_p" status --porcelain 2>/dev/null)" ]]
}

# True if the worktree at $1 has commits not yet on its upstream. When no
# upstream is configured, falls back to comparing against origin/<default>.
function _worktree_has_unpushed {
  local _p="$1"
  [[ -z "$_p" ]] && return 1
  local _up _count _def
  _up=$(git -C "$_p" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null)
  if [[ -n "$_up" ]]; then
    _count=$(git -C "$_p" rev-list --count "$_up..HEAD" 2>/dev/null)
  else
    _def=$(git -C "$_p" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null)
    _def=${_def#refs/remotes/origin/}
    [[ -z "$_def" ]] && return 1
    _count=$(git -C "$_p" rev-list --count "origin/$_def..HEAD" 2>/dev/null)
  fi
  [[ -n "$_count" && "$_count" -gt 0 ]]
}

# Echo a ref to base a new branch from. Fetches origin first (unless
# GWT_NO_FETCH=1) and prefers origin/$base when available so new worktrees
# pick up upstream commits even when local $base is stale.
function _resolve_base {
  local _base="$1"
  [[ -z "$_base" ]] && return 0
  [[ -z "$GWT_NO_FETCH" ]] && git fetch origin "$_base" --quiet 2>/dev/null
  if git rev-parse --verify --quiet "refs/remotes/origin/$_base" >/dev/null 2>&1; then
    echo "origin/$_base"
  else
    echo "$_base"
  fi
}

# Bootstrap a .treeman.yaml in the main repo if one isn't already there.
# treeman init walks the framework detector and emits a tailored config
# (Laravel/Rails/Django/...); framework-less repos still get a usable stub
# with repo.name + worktrees.root + worktrees.links. Treeman wt create
# requires this file — every gwt entry point calls it before delegating.
# `treeman init` is cwd-relative (no --repo flag), so we run it from $_main
# in a subshell to avoid disturbing the caller's PWD.
function _ensure_treeman_yaml {
  local _main="$1"
  [[ -z "$_main" ]] && return 1
  [[ -f "$_main/.treeman.yaml" ]] && return 0
  echo "gwt: bootstrapping .treeman.yaml via treeman init"
  ( cd "$_main" && treeman init )
}

# Create or attach a worktree at .worktrees/<branch> via treeman. Treeman
# owns the full lifecycle: git worktree add, env-file symlinks, env
# scoping, per-worktree DB scaffolding, postcreate hooks, and prepare.
# `wt create` is idempotent across new vs. existing branches — pass --from
# only when starting a new branch from a non-default base. The slow tail
# (postcreate + prepare) is RPC'd to the daemon when
# worktrees.async_create is on (default), so the call returns in <2s.
function _gwt_create {
  local _branch="$1" _base="$2"
  local _main=$(_git_main_root) || _main="$_git_root"
  _ensure_treeman_yaml "$_main" || return 1
  local -a _args=(wt create "$_branch" --repo "$_main")
  [[ -n "$_base" ]] && _args+=(--from "$_base")
  treeman "${_args[@]}" || return 1
  local _wt
  _wt=$(treeman wt go "$_branch" --repo "$_main") || return 1
  cd "$_wt" || return 1
}

# Attach an existing branch — same call as _gwt_create with no --from.
# Kept as a distinct entry point so _checkout_branch_or_worktree's
# create-vs-checkout routing stays readable.
# Remote-only branches (exist at origin/$b but not refs/heads/$b) need an
# explicit --from origin/$b; without it treeman creates a fresh local
# branch based on the default branch instead of the remote tip.
function _gwt_attach {
  local _branch="$1"
  if ! git rev-parse --verify --quiet "refs/heads/$_branch" >/dev/null 2>&1 \
     && git rev-parse --verify --quiet "refs/remotes/origin/$_branch" >/dev/null 2>&1; then
    _gwt_create "$_branch" "origin/$_branch"
  else
    _gwt_create "$_branch"
  fi
}

# Interactive branch-name builder. Echoes "<name>\t<base>" on stdout — both
# fields are produced inside `$(...)` so callers must parse the tab-separated
# result; an earlier version stashed the base in a global and lost it to the
# command-substitution subshell, silently basing new branches on HEAD.
# Returns 1 on cancel.
#   $1 initial token (may be empty); $2 default-base label for the prompt.
function _branch_wizard {
  local _initial="$1" _label="$2"
  local _name="$_initial"
  if [[ -z "$_name" ]]; then
    local _p="(Enter: branch name [Ticket: ABC-1234 || Tag: 4.3.21], Ctrl+C: cancel)> "
    [[ -n "$_label" ]] && _p="(Enter: new branch from $_label [Ticket: ABC-1234 || Tag: 4.3.21], Ctrl+C: cancel)> "
    _name=$(fzf --prompt="$_p" --height=~1 --no-info --print-query </dev/null)
    [[ -z "$_name" ]] && return 1
  fi

  local _final="" _base=""
  local _tag_mask='^[0-9]+\.[0-9]+\.[0-9]+([-+].*)?$'
  if [[ $_name =~ $_tag_mask ]]; then
    _base=$(_default_branch) || return 1
    _final="release/$_name"
  else
    local _prefix=$(echo -e "feature\nbugfix\nhotfix" |
      fzf --prompt="(Enter: select prefix)> " --height=~4 --no-input --no-info)
    [[ -z "$_prefix" ]] && return 1

    if [[ "$_prefix" == "hotfix" ]]; then
      _base=$(_pick_base_branch "(Enter: select base branch for hotfix)> ") || return 1
    else
      _base=$(_default_branch) || return 1
    fi

    local _suffix=$(fzf --height=~1 --no-info --print-query \
      --prompt="(Enter: select suffix)> " </dev/null)
    if [[ -n "$_suffix" ]]; then
      _suffix=${_suffix:l}
      _suffix=${_suffix// /-}
      _final="$_prefix/$_name-$_suffix"
    else
      _final="$_prefix/$_name"
    fi
  fi

  if ! git check-ref-format "refs/heads/$_final" 2>/dev/null; then
    echo "Invalid branch name: $_final" >&2
    return 1
  fi
  printf '%s\t%s\n' "$_final" "$_base"
}

if are_binary git bat fzf; then
  function gcm {
    in_git_repo || return 1

    local initial_query="$*"

    local commit_prompt
    local _branch=$(git branch --show-current)
    local commit_prefix=""
    [[ $_branch =~ '([A-Z]+-[0-9]+)' ]] && commit_prefix=$match[1]
    if [[ -z "$commit_prefix" ]]; then
      commit_prompt="(Enter: commit message; trailing \\ opens editor)> "
    else
      commit_prompt="(Enter: commit message [$commit_prefix]; trailing \\ opens editor)> "
    fi

    local commit_message=$(fzf --height=~1 \
      --query="$initial_query" \
      --no-info \
      --print-query \
      --prompt="$commit_prompt" </dev/null)

    if [[ -z "$commit_message" ]]; then
      return 0
    fi

    local -a _commit_args=()
    local _editor_mode=0
    if [[ "$commit_message" == *\\ ]]; then
      commit_message=${commit_message%\\}
      while [[ "$commit_message" == *' ' ]]; do commit_message=${commit_message% }; done
      _commit_args+=(-e)
      _editor_mode=1
    fi

    # Skip auto-prefix when the user already typed an explicit ticket prefix.
    local _final_message
    if [[ "$commit_message" =~ '^[A-Z]+-[0-9]+:' ]] || [[ -z "$commit_prefix" ]]; then
      _final_message="$commit_message"
    else
      _final_message="$commit_prefix: $commit_message"
    fi

    # `git commit -e -m ""` seeds COMMIT_EDITMSG with a leading blank line
    # that the user then has to delete. Drop -m when there's nothing to seed.
    if (( _editor_mode )) && [[ -z "$_final_message" ]]; then
      git commit "${_commit_args[@]}"
    else
      git commit "${_commit_args[@]}" -m "$_final_message"
    fi
  }

  function gp {
    in_git_repo || return 1

    local branch_name=$(git branch --show-current)
    local -a banned_branches=(develop staging production master main)
    local -a banned_patterns=('release/*' 'hotfix/*')

    # Per-repo extras via `git config --add gp.protected '<glob>'` (repeatable).
    local _extra
    while IFS= read -r _extra; do
      [[ -n "$_extra" ]] && banned_patterns+=("$_extra")
    done < <(git config --get-all gp.protected 2>/dev/null)

    local _matched=""
    if (( ${banned_branches[(Ie)$branch_name]} )); then
      _matched="protected branch '$branch_name'"
    else
      local _pat
      for _pat in "${banned_patterns[@]}"; do
        if [[ "$branch_name" == ${~_pat} ]]; then
          _matched="branch '$branch_name' matches '$_pat'"
          break
        fi
      done
    fi

    local _diverged=""
    if git rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
      local _behind=$(git rev-list --count "HEAD..@{u}" 2>/dev/null)
      if (( ${_behind:-0} > 0 )); then
        _diverged="upstream is ahead by $_behind commit(s) — push will be rejected without --force"
      fi
    fi

    if [[ -n "$_matched" ]]; then
      _confirm_destructive "Push: $_matched" || return 0
    fi
    if [[ -n "$_diverged" ]]; then
      _confirm_destructive "Push: $_diverged" || return 0
    fi

    git push -u origin "$branch_name"
  }
  function gcb {
    in_git_repo || return 1

    local initial_query=$(_trim_ws "${*:-}")
    local current_branch=$(git branch --show-current)
    _list_git_branches
    # Drop the current branch: with --select-1 it would auto-accept itself
    # when it's the only branch, blocking the Ctrl+C → wizard path.
    local -a _avail=()
    local _b
    for _b in "${reply[@]}"; do
      [[ "$_b" == "$current_branch" ]] && continue
      _avail+=("$_b")
    done
    local git_branches=${(F)_avail}

    local _max_items=3
    local _gcb_out=""
    if [[ -n "$git_branches" ]]; then
      local _n=${#_avail[@]}
      (( _n > _max_items )) && _n=$_max_items
      _gcb_out=$(echo "$git_branches" |
        fzf --prompt="(Enter: checkout, Ctrl+C: create new)> " \
          --query="$initial_query" \
          --bind 'enter:accept' \
          --exact \
          --select-1 \
          --exit-0 \
          --print-query \
          --no-info \
          --height=$((_n + 2)))
    fi
    local branch_name=$(_trim_ws "${_gcb_out##*$'\n'}")

    if [[ -n "$branch_name" && ${_avail[(r)$branch_name]} == "$branch_name" ]]; then
      _checkout_branch_or_worktree "$branch_name"
      return 0
    fi

    local _wiz_out new_branch_name new_branch_base
    _wiz_out=$(_branch_wizard "$branch_name" "") || return 0
    IFS=$'\t' read -r new_branch_name new_branch_base <<<"$_wiz_out"
    _checkout_branch_or_worktree "$new_branch_name" create "$new_branch_base"
  }

  function ga {
    in_git_repo || return 1

    if [[ -n "$@" ]]; then
      git add "$@"
    fi
    local temp_pwd="$PWD"
    cd "$_git_root"

    # Build a single list of rows: "<M|D|A>\t<path>". One panel, type-aware
    # action (M → `git add -p`; D/A → `git add`).
    local git_status=$(git status --porcelain)
    local -a _rows=()
    local _gs_line _xy _rest _wt _path
    while IFS= read -r _gs_line; do
      [[ -z $_gs_line ]] && continue
      _xy=${_gs_line:0:2}
      _rest=${_gs_line:3}
      _wt=${_xy:1:1}
      if [[ $_xy == '??' ]]; then
        if [[ -d $_rest ]]; then
          local _f
          for _f in ${_rest}**/*(.N); do
            _rows+=("A"$'\t'"$_f")
          done
        else
          _rows+=("A"$'\t'"$_rest")
        fi
      elif [[ $_wt == D ]]; then
        _rows+=("D"$'\t'"$_rest")
      elif [[ $_wt == M ]]; then
        _path=$_rest
        [[ $_path == *' -> '* ]] && _path=${_path##* -> }
        _rows+=("M"$'\t'"$_path")
      fi
    done <<<"$git_status"

    if (( ${#_rows[@]} == 0 )); then
      cd "$temp_pwd"
      echo "Nothing to stage."
      return 0
    fi

    _rows=("${(@on)_rows}")

    local _display=""
    local _r
    for _r in "${_rows[@]}"; do
      _display+="${_r%%$'\t'*}  ${_r#*$'\t'}"$'\n'
    done

    local _selected=$(printf '%s' "$_display" | fzf --multi \
      --prompt="(Tab: toggle, Enter: stage, Ctrl+C: cancel)> " \
      --header="[M]odified → patch mode  [D]eleted → stage removal  [A]dded → stage untracked" \
      --bind 'shift-tab:toggle-all' \
      --bind 'tab:toggle' \
      --bind 'enter:transform:[[ $FZF_SELECT_COUNT -gt 0 ]] && echo accept || echo abort' \
      --no-info \
      --exit-0)

    if [[ -n "$_selected" ]]; then
      local -a _lines=(${(f)_selected})
      local _line _t _p
      for _line in "${_lines[@]}"; do
        _t=${_line:0:1}
        _p=${_line:3}
        case "$_t" in
          M) git add "$_p" -p ;;
          D|A) git add "$_p" ;;
        esac
      done
    fi
    cd "$temp_pwd"
    clear
    echo -e ""
    git status --short
  }

  function gsd {
    in_git_repo || return 1

    git diff
  }

  function gd {
    in_git_repo || return 1

    local initial_query="${*:-}"
    local current_branch=$(git branch --show-current)
    _list_git_branches
    local git_branches=${(F)reply}

    local _gd_out=$(echo "$git_branches" |
      fzf --prompt="(Enter: select comparison branch)> " \
        --query="$initial_query" \
        --select-1 \
        --exit-0 \
        --print-query \
        --no-info \
        --height=~10)
    local remote_branch=${_gd_out##*$'\n'}

    if [[ -z "$remote_branch" ]]; then
      return 0
    fi

    git diff "$current_branch"..."$remote_branch" --color | bat --style=numbers --color=always -l diff
  }

  function gcd {
    in_git_repo || return 1

    local initial_query="${*:-}"
    local current_branch=$(git branch --show-current)
    _list_git_branches
    local git_branches=${(F)reply}
    local _gcd_out=$(echo "$git_branches" |
      fzf --prompt="(Enter: select target branch for diff)> " \
        --query="$initial_query" \
        --select-1 \
        --exit-0 \
        --print-query \
        --no-info \
        --height=~5)
    local target_branch=${_gcd_out##*$'\n'}

    if [[ -z "$target_branch" ]]; then
      return 0
    fi

    # Clean branch names for filename (remove remotes/origin/ prefix and special chars)
    local clean_current=${${current_branch#remotes/origin/}//\//-}
    local clean_target=${${target_branch#remotes/origin/}//\//-}
    local patch_file="${clean_current}--${clean_target}.diff"

    git diff $current_branch...$target_branch >"$patch_file"

    if [[ -f "$patch_file" ]]; then
      echo "✅ Patch file created: $patch_file"
    else
      echo "❌ Failed to create patch file"
      return 1
    fi
