    git reset --hard "HEAD~$_n"
  }
  function gr {
    in_git_repo || return 1
    local _n=${1:-1}
    git reset --soft "HEAD~$_n"
  }
  function gsa {
    in_git_repo || return 1

    git stash
  }
  # Confirm a destructive action via fzf Yes/No. Returns 0 on Yes, 1 otherwise.
  function _confirm_destructive {
    local choice=$(printf 'No\nYes\n' |
      fzf \
        --no-input \
        --header="$1" \
        --reverse \
        --height=4 \
        --no-info \
        --no-multi \
        --exit-0)
    [[ "$choice" == "Yes" ]]
  }

  function gw {
    in_git_repo || return 1
    if [[ "$1" == "--all" || "$1" == "-a" ]]; then
      _confirm_destructive "[WARN] Wipe working changes + entire stash stack" || return 0
      git stash push -u >/dev/null 2>&1
      git stash clear
      return 0
    fi
    [[ -z "$(git status --porcelain)" ]] && return 0
    _confirm_destructive "[WARN] Local Branch: Wipe Non-Pushed Changes" || return 0
    git stash push -u >/dev/null && git stash drop
  }

  function ggo {
    in_git_repo || return 1

    local initial_query="${1:-}"
    _list_git_branches
    local git_branches=${(F)reply}

    local selected_branch=$(echo -e "$git_branches" |
      fzf --prompt="(Enter: select branch to pull from origin)> " \
        --query="$initial_query" \
        --select-1 \
        --exit-0 \
        --no-info \
        --height=10)

    if [[ -n "$selected_branch" ]]; then
      git pull origin "$selected_branch"
    fi
  }
  function gl {
    in_git_repo || return 1

    local initial_query="${1:-}"

    # Resolve a clipboard binary at call time so the fzf subshell gets a
    # concrete command (it doesn't inherit zsh aliases).
    local _clip=""
    if command -v xclip >/dev/null 2>&1; then _clip='xclip -selection clipboard'
    elif command -v wl-copy >/dev/null 2>&1; then _clip='wl-copy'
    elif command -v pbcopy >/dev/null 2>&1; then _clip='pbcopy'
    fi

    local -a _binds=(
      --bind 'ctrl-x:become(git cherry-pick {1})'
      --bind 'ctrl-r:become(git revert {1})'
    )
    local _prompt_hints="Enter: show, Ctrl+X: cherry-pick, Ctrl+R: revert"
    if [[ -n "$_clip" ]]; then
      _binds+=(--bind "ctrl-y:execute-silent(printf '%s' {1} | $_clip)")
      _prompt_hints+=", Ctrl+Y: copy hash"
    fi
    _prompt_hints+=", Ctrl+C: cancel"

    local _commit_line=$(git log --oneline --color=always |
      fzf --ansi \
        --prompt="($_prompt_hints)> " \
        --query="$initial_query" \
        --no-sort \
        --exact \
        --exit-0 \
        --no-info \
        --preview='git show --stat --patch --color=always {1} 2>/dev/null | bat --style=numbers --color=always -l diff' \
        --preview-window='up:90%:wrap:nohidden' \
        --height=50% \
        "${_binds[@]}")
    local commit=${_commit_line%% *}

    if [[ -n "$commit" ]]; then
      git show --stat --patch --color=always "$commit" | bat --style=numbers --color=always -l diff
    fi
  }

  function gsp {
    in_git_repo || return 1

    local stash_list=$(git stash list)
    if [[ -z "$stash_list" ]]; then
      echo "No stashes found."
      return 0
    fi

    local selected=$(echo "$stash_list" |
      fzf --prompt="(Enter: pop stash, Ctrl+C: cancel)> " \
        --no-sort \
        --exit-0 \
        --no-info \
        --preview='line={}; git stash show -p --color=always "${line%%:*}" 2>/dev/null | bat --style=numbers --color=always -l diff' \
        --preview-window='up:90%:wrap:nohidden' \
        --height=50%)

    if [[ -z "$selected" ]]; then
      return 0
    fi

    local stash_ref=${selected%%:*}
    git stash pop "$stash_ref"
  }

  function gcp {
    in_git_repo || return 1

    # Refuse to start if a cherry-pick is already in progress — surface the
    # half-finished state instead of stacking another on top.
    if [[ -f "$(git rev-parse --git-dir 2>/dev/null)/CHERRY_PICK_HEAD" ]]; then
      echo "Cherry-pick already in progress:"
      echo "  Continue: git cherry-pick --continue"
      echo "  Skip:     git cherry-pick --skip"
      echo "  Abort:    git cherry-pick --abort"
      return 1
    fi

    if [[ -n "$(git status --porcelain --untracked-files=no 2>/dev/null)" ]]; then
      _confirm_destructive "[WARN] Working tree not clean — cherry-pick may abort mid-way. Continue?" || return 0
    fi

    local initial_query="${1:-}"
    local _selected=$(git log --oneline --color=always --all |
      fzf --ansi \
        --multi \
        --prompt="(Tab: toggle commit, Enter: cherry-pick selection, Ctrl+C: cancel)> " \
        --query="$initial_query" \
        --no-sort \
        --exit-0 \
        --no-info \
        --bind 'tab:toggle' \
        --bind 'shift-tab:toggle-all' \
        --preview='git show --stat --patch --color=always {1} 2>/dev/null | bat --style=numbers --color=always -l diff' \
        --preview-window='up:90%:wrap:nohidden' \
        --height=50%)

    if [[ -z "$_selected" ]]; then
      return 0
    fi

    # Extract hashes, reverse so oldest commit applies first (log is newest-first).
    # (Oa) = reverse-array order flag.
    local -a _lines=(${(f)_selected})
    local -a _hashes=("${_lines[@]%% *}")
    git cherry-pick "${(Oa)_hashes[@]}"
    local _rc=$?
    if (( _rc != 0 )); then
      echo ""
      echo "Cherry-pick stopped (exit $_rc). Working tree may have conflicts."
      echo "  Resolve + stage, then: git cherry-pick --continue"
      echo "  Skip current commit:   git cherry-pick --skip"
      echo "  Abort entirely:        git cherry-pick --abort"
      return $_rc
    fi
  }

fi

if are_binary git fzf; then
  function gwt {
    in_git_repo || return 1

    local _start_pwd="$PWD"

    # `gwt -` — toggle to the previously-visited worktree.
    if [[ "$1" == "-" ]]; then
      if [[ -z "$_GWT_LAST" || ! -d "$_GWT_LAST" ]]; then
        echo "gwt: no previous worktree"
        return 1
      fi
      cd "$_GWT_LAST" || return 1
      typeset -g _GWT_LAST="$_start_pwd"
      return 0
    fi

    {
    local current_worktree="$_git_root"
    local repo_root=$(_git_main_root) || repo_root="$current_worktree"

    # If we're leaving a clean linked worktree, remove it after the switch.
    local _prev_clean_worktree=""
    if _in_linked_worktree && [[ -z "$(git status --porcelain)" ]]; then
      _prev_clean_worktree="$current_worktree"
    fi

    local worktrees_dir="$repo_root/.worktrees"

    # Build worktree rows, sorted newest-first by HEAD commit timestamp.
    local occupied_branches=""
    local -a _wt_rows=()
    local _path _branch _ts
    while IFS=$'\t' read -r _path _branch; do
      occupied_branches+="$_branch"$'\n'
      [[ "$_path" == "$current_worktree" ]] && continue
      _ts=$(git -C "$_path" log -1 --format=%at HEAD 2>/dev/null)
      _ts=${_ts:-0}
      _wt_rows+=("$_ts"$'\t'"$_path"$'\t'"$_branch")
    done < <(_list_worktrees)
    _wt_rows=("${(@On)_wt_rows}")
    local worktree_entries=""
    local _row _rest
    for _row in "${_wt_rows[@]}"; do
      _rest=${_row#*$'\t'}
      _path=${_rest%%$'\t'*}
      _branch=${_rest#*$'\t'}
      worktree_entries+="$_path  $_branch"$'\n'
    done

    _list_git_branches
    local all_branches=${(F)reply}

    local available_branches
    if [[ -n "$occupied_branches" ]]; then
      local -a _occ=(${(f)occupied_branches})
      local -a _avail=()
      local _b
      while IFS= read -r _b; do
        [[ -z $_b ]] && continue
        [[ ${_occ[(r)$_b]} == "$_b" ]] || _avail+=("$_b")
      done <<<"$all_branches"
      available_branches=${(F)_avail}
    else
      available_branches="$all_branches"
    fi

    local display_list=""
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      local wt_path=${line%% *}
      local wt_branch=${line##* }
      local marker=""
      _worktree_is_dirty "$wt_path" && marker+="*"
      _worktree_has_unpushed "$wt_path" && marker+="!"
      [[ -n "$marker" ]] && marker=" $marker"
      display_list+="[worktree] $wt_branch$marker  →  $wt_path"$'\n'
    done <<<"$worktree_entries"

    while IFS= read -r branch; do
      [[ -z "$branch" ]] && continue
      display_list+="[branch]   $branch"$'\n'
    done <<<"$available_branches"

    if [[ -z "$display_list" ]]; then
      echo "No worktrees or available branches found."
      return 0
    fi

    # Fixed 3-item list + preview scaled to terminal height
    local _list_h=4 # prompt(1) + items(3)
    local _prev_h=$((${LINES:-40} * 50 / 100))
    local selected=$(echo "$display_list" |
      fzf --prompt="(Enter: switch/create, Ctrl+C: wizard create from scratch)> " \
        --print-query \
        --exit-0 \
        --no-info \
        --height=$((_list_h + _prev_h)) \
        --preview='
          line={}
          if [[ ${line%% *} == "[worktree]" ]]; then
            p=${line##*  →  }
            git -C "$p" log --oneline --color=always -10 2>/dev/null
          else
            b=${line#"[branch]   "}
            git log --oneline --color=always -10 "$b" 2>/dev/null
          fi
        ' \
        --preview-window="down:${_prev_h}:wrap:nohidden")

    local query=${selected%%$'\n'*}
    local match=${selected##*$'\n'}

    # No match (typed-new OR Ctrl+C) → enter create path. Names that already
    # contain a slash (e.g. `feature/foo`, `release/1.2.3`) are taken as-is
    # and we just ask for a base. Bare names (or empty, from Ctrl+C) route
    # through `_branch_wizard` to enforce the feature/bugfix/hotfix/release
    # prefix convention.
    if [[ -z "$match" || "$match" == "$query" ]]; then
      local _new_name="$query" _base=""
      if [[ "$_new_name" == */* ]]; then
        local base_branch=$(echo "$all_branches" |
          fzf --prompt="(Enter: select base branch for '$_new_name')> " \
            --select-1 \
            --exit-0 \
            --no-info \
            --height=30%)
        [[ -z "$base_branch" ]] && return 0
        _base=$base_branch
      else
        _new_name=$(_branch_wizard "$_new_name" "") || return 0
        _base=$_branch_base_out
      fi
      # Wizard may have produced an already-existing branch — handle the
      # swap-to-existing case the same way `_checkout_branch_or_worktree`
      # does, so the wizard never silently re-creates.
      local _existing_wt=$(_worktree_path_for_branch "$_new_name")
      if [[ -n "$_existing_wt" && "$_existing_wt" != "$_git_root" ]]; then
        cd "$_existing_wt" || return 1
        echo "Switched to existing worktree: $_existing_wt"
        _gwt_remove_if_clean "$_prev_clean_worktree"
        return 0
      fi
      if git rev-parse --verify --quiet "refs/heads/$_new_name" >/dev/null 2>&1; then
        _gwt_attach "$_new_name" || return 1
      else
        _gwt_create "$_new_name" "$_base" || return 1
      fi
      _gwt_remove_if_clean "$_prev_clean_worktree"
      return 0
    fi

    local entry_type=${match%% *}

    if [[ "$entry_type" == "[worktree]" ]]; then
      local target_path=${match##*  →  }
      cd "$target_path" || return 1
    else
      local branch_name=${match#"[branch]   "}
      _gwt_attach "$branch_name" || return 1
    fi
    _gwt_remove_if_clean "$_prev_clean_worktree"
    } always {
      [[ "$PWD" != "$_start_pwd" ]] && typeset -g _GWT_LAST="$_start_pwd"
    }
  }

  function gwtd {
    in_git_repo || return 1

    local target="$1"
    local repo_root=$(_git_main_root) || repo_root="$_git_root"

    local linked_worktrees=""
    local _path _branch
    while IFS=$'\t' read -r _path _branch; do
      [[ "$_path" == "$repo_root" ]] && continue
      local _marker=""
      _worktree_is_dirty "$_path" && _marker+="*"
      _worktree_has_unpushed "$_path" && _marker+="!"
      [[ -n "$_marker" ]] && _marker=" $_marker"
      linked_worktrees+="$_branch$_marker  →  $_path"$'\n'
    done < <(_list_worktrees)

    if [[ -z "$linked_worktrees" ]]; then
      echo "No linked worktrees found."
      return 0
    fi

    local selected=""
    if [[ -n "$target" ]]; then
      local _entry
      while IFS= read -r _entry; do
        local _ebranch=${_entry%%  →  *}
        local _ebranch_clean="$_ebranch"
        _ebranch_clean=${_ebranch_clean% \*\!}
        _ebranch_clean=${_ebranch_clean% \!}
        _ebranch_clean=${_ebranch_clean% \*}
        local _epath=${_entry##*  →  }
        if [[ "$_ebranch_clean" == "$target" || "$_epath" == "$target" ]]; then
          selected="$_entry"
          break
        fi
      done <<<"$linked_worktrees"
    else
      selected=$(echo "$linked_worktrees" |
        fzf --prompt="(Enter: select worktree to remove)> " \
          --select-1 \
          --exit-0 \
          --no-info \
          --height=~10)
    fi

    if [[ -z "$selected" ]]; then
      return 0
    fi

    local worktree_path=${selected##*  →  }

    if [[ "$PWD" == "$worktree_path"* ]]; then
      cd "$repo_root" || return 1
    fi

    local -a _msgs=()
    _worktree_is_dirty "$worktree_path" && _msgs+=("uncommitted changes")
    _worktree_has_unpushed "$worktree_path" && _msgs+=("unpushed commits")
    local _force=""
    if (( ${#_msgs[@]} )); then
      local _why=${(j:, :)_msgs}
      _confirm_destructive "[WARN] Worktree '$worktree_path' has $_why — destroy?" || return 0
      _force="--force"
    fi
    if ! _gwt_predelete "$worktree_path" "$repo_root"; then
      _confirm_destructive "[WARN] predelete hook failed — destroy '$worktree_path' anyway?" || return 0
    fi
    git worktree remove ${_force} "$worktree_path" || return 1
    git worktree prune --expire now >/dev/null 2>&1

    # Clean up empty parent dirs inside .worktrees/ (e.g. feature/ after
    # removing feature/foo).
    local _wt_root="$repo_root/.worktrees"
    local _parent="${worktree_path:h}"
    while [[ "$_parent" == "$_wt_root"/* ]]; do
      rmdir "$_parent" 2>/dev/null || break
      _parent="${_parent:h}"
    done
  }

  # Scaffold .gwt-postcreate and .gwt-predelete in the repo root if missing,
  # then open both in $EDITOR. Idempotent — existing files are left untouched.
  function gwth {
    in_git_repo || return 1
    local _main=$(_git_main_root) || _main="$_git_root"
    local _post="$_main/.gwt-postcreate"
    local _pre="$_main/.gwt-predelete"

    if [[ ! -e "$_post" ]]; then
      cat >"$_post" <<'EOF'
#!/usr/bin/env bash
# Runs in the background after `gwt` creates a new worktree. Replaces the
# built-in lockfile-based dep install — wire up whatever your project needs
# (compose up, db seed, env scaffolding, etc.).
# Cwd:  the new worktree.
# Env:  GWT_MAIN (main repo root), GWT_WT (this worktree path).
# Logs: <worktree>/.gwt-postcreate.log (stdout + stderr).
set -euo pipefail
EOF
      chmod +x "$_post"
      echo "gwth: created $_post"
    fi

    if [[ ! -e "$_pre" ]]; then
      cat >"$_pre" <<'EOF'
#!/usr/bin/env bash
# Runs synchronously before `gwtd` removes a worktree, and before the
# auto-removal of a clean linked worktree on switch via `gwt`. Use for
# external cleanup that git itself won't do (drop branch DB, tear down
# compose project, remove reverse-proxy entry, etc.).
# Cwd: the worktree being removed.
# Env: GWT_MAIN (main repo root), GWT_WT (worktree path).
# Exit non-zero to block the removal — interactive `gwtd` will prompt to
# override, the silent auto-remove path will keep the worktree.
set -euo pipefail
EOF
      chmod +x "$_pre"
      echo "gwth: created $_pre"
    fi

    ${EDITOR:-vi} "$_post" "$_pre"
  }
fi

