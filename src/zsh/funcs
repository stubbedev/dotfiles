      git pull --all
    else
      git pull
    fi
  }
  function gf {
    in_git_repo || return 1

    if [[ "$1" == "--all" || "$1" == "-a" ]]; then
      git fetch --all
    else
      git fetch
    fi
  }
  function ghr {
    in_git_repo || return 1
    local _n=${1:-1}
