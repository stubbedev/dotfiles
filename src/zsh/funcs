    _list_git_branches
    local git_branches=${(F)reply}

    local selected_branch=$(echo -e "$git_branches" |
      fzf --prompt="(Enter: select branch to pull from origin)> " \
        --query="$initial_query" \
        --select-1 \
        --exit-0 \
        --no-info \
        --height=~10)

    if [[ -n "$selected_branch" ]]; then
