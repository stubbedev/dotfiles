  # Enter (or anything not n/N) confirms; only n/N cancels.
  function _confirm_destructive {
    local _Y=$'\e[33m' _G=$'\e[32m' _R=$'\e[31m' _Z=$'\e[0m'
    local _reply
    read -ks 1 "_reply?${_Y}$1 [${_G}Y${_Y}/${_R}n${_Y}]${_Z} "
    print
    if [[ "$_reply" == [nN] ]]; then
      return 1
    fi
    return 0
