    elif command -v wl-copy >/dev/null 2>&1; then _clip='wl-copy'
    elif command -v pbcopy >/dev/null 2>&1; then _clip='pbcopy'
    fi

    # Multi-select: Tab to mark commits, then Ctrl+X cherry-picks the lot.
    # `{+1}` is space-separated hashes (newest-first since git log is);
    # `tac` flips to oldest-first so cherry-pick replays history forward.
    local -a _binds=(
      --bind 'tab:toggle'
      --bind 'shift-tab:toggle-all'
      --bind 'ctrl-x:become(printf "%s\n" {+1} | tac | xargs git cherry-pick)'
      --bind 'ctrl-r:become(git revert {+1})'
    )
    local _prompt_hints="Tab: toggle, Enter: show, Ctrl+X: cherry-pick, Ctrl+R: revert"
    if [[ -n "$_clip" ]]; then
      _binds+=(--bind "ctrl-y:execute-silent(printf '%s' {1} | $_clip)")
      _prompt_hints+=", Ctrl+Y: copy hash"
    fi
    _prompt_hints+=", Ctrl+C: cancel"

    local _commit_line=$(git log --oneline --color=always |
      fzf --ansi \
        --multi \
        --prompt="($_prompt_hints)> " \
        --query="$initial_query" \
        --no-sort \
        --exact \
        --exit-0 \
        --no-info \
        --height=~10 \
        "${_binds[@]}")
    local commit=${_commit_line%% *}

    if [[ -n "$commit" ]]; then
      git show --stat --patch --color=always "$commit" | bat --style=numbers --color=always -l diff
    fi
  }

  function gsp {
    in_git_repo || return 1

    local stash_list=$(git stash list)
    if [[ -z "$stash_list" ]]; then
      echo "No stashes found."
      return 0
    fi

    local selected=$(echo "$stash_list" |
      fzf --prompt="(Enter: pop stash, Ctrl+C: cancel)> " \
        --no-sort \
        --exit-0 \
        --no-info \
        --height=~10)

    if [[ -z "$selected" ]]; then
      return 0
    fi

    local stash_ref=${selected%%:*}
    git stash pop "$stash_ref"
  }

fi

if are_binary git fzf treeman; then
  function gwt {
    in_git_repo || return 1

    local _start_pwd="$PWD"

    # `gwt -` — toggle to the previously-visited worktree. Falls back to
    # `treeman wt prev` when the per-shell `$_GWT_LAST` is unset (fresh
    # tab, post-resume tmux session) so cross-shell toggle still works
    # off the SQLite-backed last_visited_at timestamp.
    if [[ "$1" == "-" ]]; then
      local _target=""
      if [[ -n "$_GWT_LAST" && -d "$_GWT_LAST" ]]; then
        _target="$_GWT_LAST"
      else
        local _main=$(_git_main_root 2>/dev/null) || _main=""
        if [[ -n "$_main" ]]; then
          _target=$(treeman wt prev --repo "$_main" 2>/dev/null)
        fi
      fi
      if [[ -z "$_target" || ! -d "$_target" ]]; then
        echo "gwt: no previous worktree"
        return 1
      fi
      cd "$_target" || return 1
      typeset -g _GWT_LAST="$_start_pwd"
      return 0
    fi

    # Non-interactive entry for scripts/agents — bypass fzf entirely. Mirrors
    # the interactive "new branch" path (always a .worktrees/<branch> worktree
    # via treeman), never `git checkout -b` in place. Echoes the resolved
    # worktree path on success.
    #   gwt -c|--create <branch> [-b|--base <base>]  create-or-switch
    #   gwt -s|--switch <branch>                      switch/attach existing
    #   gwt -p|--path   <branch>                      echo path only, no cd
    # --create defaults base to the repo default branch; pass --base for
    # hotfix or any non-default start point.
    if [[ "$1" == -* ]]; then
      local _mode="" _branch="" _base=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          -c|--create) _mode="create"; _branch="$2"; shift 2 ;;
          -s|--switch) _mode="switch"; _branch="$2"; shift 2 ;;
          -p|--path)   _mode="path";   _branch="$2"; shift 2 ;;
          -b|--base)   _base="$2";     shift 2 ;;
          *) echo "gwt: unknown flag '$1'" >&2; return 2 ;;
        esac
      done
      [[ -z "$_mode" ]]   && { echo "gwt: no mode flag (-c/-s/-p)" >&2; return 2; }
      [[ -z "$_branch" ]] && { echo "gwt: --$_mode needs a branch name" >&2; return 2; }

      local _wt=$(_worktree_path_for_branch "$_branch")
      case "$_mode" in
        path)
          [[ -n "$_wt" ]] || { echo "gwt: no worktree for '$_branch'" >&2; return 1; }
          echo "$_wt"; return 0 ;;
        switch)
          if [[ -n "$_wt" && "$_wt" != "$_git_root" ]]; then
            cd "$_wt" || return 1
          else
            _gwt_attach "$_branch" || return 1
          fi
          echo "$PWD"; return 0 ;;
        create)
          if [[ -n "$_wt" && "$_wt" != "$_git_root" ]]; then
            cd "$_wt" || return 1
          elif git rev-parse --verify --quiet "refs/heads/$_branch" >/dev/null 2>&1; then
            _gwt_attach "$_branch" || return 1
          else
            [[ -z "$_base" ]] && { _base=$(_default_branch) || return 1; }
            _gwt_create "$_branch" "$_base" || return 1
          fi
          echo "$PWD"; return 0 ;;
      esac
    fi

    {
    local current_worktree="$_git_root"
    local repo_root=$(_git_main_root) || repo_root="$current_worktree"

    # If we're leaving a clean linked worktree, remove it after the switch.
    local _prev_clean_worktree=""
    if _in_linked_worktree && [[ -z "$(git status --porcelain)" ]]; then
      _prev_clean_worktree="$current_worktree"
    fi

    local worktrees_dir="$repo_root/.worktrees"

    # Build worktree rows, sorted newest-first by HEAD commit timestamp.
    local occupied_branches=""
    local -a _wt_rows=()
    local _path _branch _ts
    while IFS=$'\t' read -r _path _branch; do
      occupied_branches+="$_branch"$'\n'
      [[ "$_path" == "$current_worktree" ]] && continue
      _ts=$(git -C "$_path" log -1 --format=%at HEAD 2>/dev/null)
      _ts=${_ts:-0}
      _wt_rows+=("$_ts"$'\t'"$_path"$'\t'"$_branch")
    done < <(_list_worktrees)
    _wt_rows=("${(@On)_wt_rows}")
    local worktree_entries=""
    local _row _rest
    for _row in "${_wt_rows[@]}"; do
      _rest=${_row#*$'\t'}
      _path=${_rest%%$'\t'*}
      _branch=${_rest#*$'\t'}
      worktree_entries+="$_path  $_branch"$'\n'
    done

    _list_git_branches
    local all_branches=${(F)reply}

    local available_branches
    if [[ -n "$occupied_branches" ]]; then
      local -a _occ=(${(f)occupied_branches})
      local -a _avail=()
