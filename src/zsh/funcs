#!/usr/bin/env zsh
# shellcheck disable=SC1091

if is_binary php; then
  function art {
    if is_file "$PWD/artisan"; then
      php artisan "$@"
    elif is_binary artisan; then
      artisan "$@"
    else
      echo "No artisan on current PATH"
    fi
  }
fi

typeset -gA _git_shorthand_docs=(
  gcm 'git commit with auto ticket prefix from branch name'
  gp 'git push (warns on protected branches)'
  gcb 'checkout or create branch (feature/bugfix/hotfix prefixes)'
  gcr 'create release branch with semver bump (major/minor/patch)'
  ga 'interactively stage files with diff preview'
  gsd 'show working tree diff'
  gd 'diff current branch against another branch'
  gcd 'export branch diff to a patch file'
  gst 'git status (short format)'
  gg 'git pull current branch from origin'
  gga 'git pull --all'
  gf 'git fetch'
  gfa 'git fetch --all'
  ghr 'hard reset HEAD~ (discard last commit and changes)'
  ghrn 'hard reset HEAD~N (discard last N commits and changes)'
  gr 'soft reset HEAD~ (undo last commit, keep changes staged)'
  grn 'soft reset HEAD~N (undo last N commits, keep changes staged)'
  gsa 'stash all local changes'
  gw 'wipe local changes (stash + drop)'
  gwa 'wipe all local changes including stash (stash + clear)'
  ggo 'pull from a selected origin branch'
  gl 'interactive git log browser with commit preview'
  gsp 'interactive stash pop (fzf select from stash list)'
  gcp 'interactive cherry-pick from log (multi-select, oldest first)'
  gwt 'switch to or create git worktree'
  gwtd 'remove a git worktree'
  gcbw 'create branch in worktree from default branch (feature/bugfix/hotfix prefixes)'
)

# Walk up directory tree looking for .git (handles regular repos and worktrees).
# Sets _git_root to the repo/worktree root. No git fork needed.
function in_git_repo {
  local dir=$PWD
  while [[ $dir != / ]]; do
    if [[ -e $dir/.git ]]; then
      _git_root=$dir
      return 0
    fi
    dir=${dir:h}
  done
  return 1
}

# In a linked worktree, $_git_root/.git is a file (gitlink). In the main repo
# it's a directory. Requires _git_root to be set (call in_git_repo first).
function _in_linked_worktree {
  [[ -f "$_git_root/.git" ]]
}

# Path of the main repo root, regardless of which worktree we're in.
function _git_main_root {
  local _common=$(git rev-parse --git-common-dir 2>/dev/null)
  [[ -z "$_common" ]] && return 1
  [[ "$_common" != /* ]] && _common="$(cd "$_common" && pwd -P)"
  if [[ "$_common" == */.git ]]; then
    echo "${_common%/.git}"
  else
    echo "$_common"
  fi
}

# Remove the previous worktree if we've moved out of it. Caller must have
# already verified it was clean before the switch. Skipped if the worktree
# has commits that aren't on its upstream — those would be silently lost.
function _gwt_remove_if_clean {
  local _prev="$1"
  [[ -z "$_prev" ]] && return 0
  [[ "$PWD" == "$_prev" || "$PWD" == "$_prev"/* ]] && return 0
  if _worktree_has_unpushed "$_prev"; then
    echo "gwt: keeping $_prev (has unpushed commits)"
    return 0
  fi
  (
    if git worktree remove "$_prev" 2>/dev/null; then
      git worktree prune --expire now >/dev/null 2>&1
    fi
  ) &!
}

# Emit one "<path>\t<branch>" line per linked worktree on a branch.
# Worktrees in detached HEAD or bare are skipped (no `branch` line).
function _list_worktrees {
  local _wt_path="" _wt_branch="" _wt_line
  while IFS= read -r _wt_line; do
    if [[ $_wt_line == worktree\ * ]]; then
      _wt_path=${_wt_line#worktree }
      _wt_branch=""
    elif [[ $_wt_line == branch\ * ]]; then
      _wt_branch=${_wt_line#branch refs/heads/}
    elif [[ -z $_wt_line ]]; then
      [[ -n $_wt_branch && -n $_wt_path ]] && printf '%s\t%s\n' "$_wt_path" "$_wt_branch"
      _wt_path="" _wt_branch=""
    fi
  done < <(
    git worktree list --porcelain 2>/dev/null
    echo
  )
}

# Print the path of the worktree that has $1 checked out, or nothing if none.
function _worktree_path_for_branch {
  local _target="$1" _path _branch
  while IFS=$'\t' read -r _path _branch; do
    [[ "$_branch" == "$_target" ]] && { echo "$_path"; return 0; }
  done < <(_list_worktrees)
  return 1
}

# Switch to or create a branch with worktree-aware routing.
# Args: $1 branch, $2 mode ("checkout" default | "create"), $3 base for create
# Strategy:
#   1. Branch already in another worktree → cd there
#   2. In a linked worktree and main repo clean → cd to main, checkout/create there
#   3. In a linked worktree and main dirty → create a new worktree for the branch
#   4. Otherwise → checkout/create in place
# Requires _git_root to be set (call in_git_repo first).
function _checkout_branch_or_worktree {
  local _target="$1" _mode="${2:-checkout}" _base="$3"
  [[ -z "$_target" ]] && return 1

  local _existing_wt=$(_worktree_path_for_branch "$_target")
  if [[ -n "$_existing_wt" && "$_existing_wt" != "$_git_root" ]]; then
    cd "$_existing_wt" || return 1
    echo "Switched to worktree: $_existing_wt"
    return 0
  fi

  # If asked to create but branch exists locally, fall back to checkout
  if [[ "$_mode" == "create" ]] && git rev-parse --verify --quiet "refs/heads/$_target" >/dev/null 2>&1; then
    _mode="checkout"
    _base=""
  fi

  local -a _action
  if [[ "$_mode" == "create" ]]; then
    if [[ -n "$_base" ]]; then
      _action=(git checkout -b "$_target" "$_base")
    else
      _action=(git checkout -b "$_target")
    fi
  else
    _action=(git checkout "$_target")
  fi

  if ! _in_linked_worktree; then
    "${_action[@]}"
    return $?
  fi

  local _main=$(_git_main_root)
  if [[ -z "$(git -C "$_main" status --porcelain 2>/dev/null)" ]]; then
    cd "$_main" || return 1
    "${_action[@]}"
    return $?
  fi

  if [[ "$_mode" == "create" ]]; then
    _gwt_create "$_target" "$_base"
  else
    _gwt_attach "$_target"
  fi
}

# Fork-free branch listing: sets $reply to sorted-unique branch array.
# Uses %(refname) to avoid parsing git's marker/color output entirely.
function _list_git_branches {
  local -a _arr=()
  local _b
  while IFS= read -r _b; do
    if [[ $_b == refs/heads/* ]]; then
      _arr+=("${_b#refs/heads/}")
    elif [[ $_b == refs/remotes/origin/* ]]; then
      local _rb=${_b#refs/remotes/origin/}
      [[ $_rb == HEAD ]] && continue
      _arr+=("$_rb")
    fi
  done < <(git branch --all --format='%(refname)' 2>/dev/null)
  reply=(${(ou)_arr})
}

# Resolve repo default branch via origin/HEAD, falling back to master/main.
# Echoes the branch name; returns 1 if it can't be determined.
function _default_branch {
  local _default=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null)
  _default=${_default#refs/remotes/origin/}
  if [[ -z "$_default" ]]; then
    local _b
    for _b in master main; do
      if git rev-parse --verify --quiet "refs/heads/$_b" >/dev/null 2>&1; then
        _default=$_b
        break
      fi
    done
  fi
  [[ -z "$_default" ]] && return 1
  echo "$_default"
}

# Prompt for a base branch via fzf. Echoes selection; returns 1 if cancelled.
function _pick_base_branch {
  local _prompt="${1:-(Enter: select base branch)> }"
  _list_git_branches
  local _branches=${(F)reply}
  local _picked=$(echo "$_branches" |
    fzf --prompt="$_prompt" \
      --no-info \
      --height=30%)
  [[ -z "$_picked" ]] && return 1
  echo "$_picked"
}

# True if the worktree at $1 has any uncommitted changes.
function _worktree_is_dirty {
  local _p="$1"
  [[ -z "$_p" ]] && return 1
  [[ -n "$(git -C "$_p" status --porcelain 2>/dev/null)" ]]
}

# True if the worktree at $1 has commits not yet on its upstream. When no
# upstream is configured, falls back to comparing against origin/<default>.
function _worktree_has_unpushed {
  local _p="$1"
  [[ -z "$_p" ]] && return 1
  local _up _count _def
  _up=$(git -C "$_p" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null)
  if [[ -n "$_up" ]]; then
    _count=$(git -C "$_p" rev-list --count "$_up..HEAD" 2>/dev/null)
  else
    _def=$(git -C "$_p" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null)
    _def=${_def#refs/remotes/origin/}
    [[ -z "$_def" ]] && return 1
    _count=$(git -C "$_p" rev-list --count "origin/$_def..HEAD" 2>/dev/null)
  fi
  [[ -n "$_count" && "$_count" -gt 0 ]]
}

# Echo a ref to base a new branch from. Fetches origin first (unless
# GWT_NO_FETCH=1) and prefers origin/$base when available so new worktrees
# pick up upstream commits even when local $base is stale.
function _resolve_base {
  local _base="$1"
  [[ -z "$_base" ]] && return 0
  [[ -z "$GWT_NO_FETCH" ]] && git fetch origin "$_base" --quiet 2>/dev/null
  if git rev-parse --verify --quiet "refs/remotes/origin/$_base" >/dev/null 2>&1; then
    echo "origin/$_base"
  else
    echo "$_base"
  fi
}

# Symlink uncommitted-but-needed files from the main repo into a new worktree.
# Defaults: .env, .env.local, .env.*.local, .envrc. A .gwt-link file in the
# main repo root overrides the defaults (one glob pattern per line, # comments).
function _gwt_link_files {
  local _main="$1" _wt="$2"
  [[ -z "$_main" || -z "$_wt" || "$_main" == "$_wt" ]] && return 0
  emulate -L zsh
  setopt null_glob
  local -a _patterns
  if [[ -f "$_main/.gwt-link" ]]; then
    local _line
    while IFS= read -r _line; do
      [[ -z $_line || $_line == \#* ]] && continue
      _patterns+=("$_line")
    done <"$_main/.gwt-link"
  else
    _patterns=('.env' '.env.local' '.env.*.local' '.envrc')
  fi
  local _pat _src _rel _dst _linked_envrc=0
  for _pat in "${_patterns[@]}"; do
    for _src in "$_main"/${~_pat}; do
      [[ -e "$_src" || -L "$_src" ]] || continue
      _rel=${_src#$_main/}
      _dst="$_wt/$_rel"
      [[ -e "$_dst" || -L "$_dst" ]] && continue
      mkdir -p "${_dst:h}"
      if ln -s "$_src" "$_dst" 2>/dev/null; then
        echo "gwt: linked $_rel"
        [[ "$_rel" == ".envrc" ]] && _linked_envrc=1
      fi
    done
  done
  if (( _linked_envrc )) && command -v direnv >/dev/null 2>&1; then
    direnv allow "$_wt" 2>/dev/null && echo "gwt: direnv allowed $_wt"
  fi
}

# Run project setup in the new worktree. If <main>/.gwt-postcreate exists and
# is executable, run it (project owns the setup). Otherwise detect a lockfile
# and dispatch the matching install command. Output goes to
# <worktree>/.gwt-postcreate.log. Skipped when GWT_NO_INSTALL=1.
function _gwt_postcreate {
  local _wt="$1" _main="$2"
  [[ -z "$_wt" || -n "$GWT_NO_INSTALL" ]] && return 0
  local _log="$_wt/.gwt-postcreate.log"
  if [[ -n "$_main" && -x "$_main/.gwt-postcreate" ]]; then
    echo "gwt: running $_main/.gwt-postcreate in bg → tail -f $_log"
    ( cd "$_wt" && GWT_MAIN="$_main" GWT_WT="$_wt" "$_main/.gwt-postcreate" >"$_log" 2>&1 ) &!
    return 0
  fi
  # Detect every present stack; spawn each install in its own bg job with
  # its own log so output doesn't interleave. JS managers are mutually
  # exclusive (at most one lockfile per project).
  local -A _stacks=()
  if [[ -f "$_wt/composer.lock" || -f "$_wt/composer.json" ]] && command -v composer >/dev/null 2>&1; then
    _stacks[composer]="composer install --no-interaction"
  fi
  # JS manager preference: yarn > bun > pnpm > npm. Fall back to plain
  # `npm install` for projects without a manager-specific lockfile.
  if [[ -f "$_wt/yarn.lock" ]] && command -v yarn >/dev/null 2>&1; then
    _stacks[yarn]="yarn install --frozen-lockfile"
  elif [[ -f "$_wt/bun.lockb" ]] && command -v bun >/dev/null 2>&1; then
    _stacks[bun]="bun install"
  elif [[ -f "$_wt/pnpm-lock.yaml" ]] && command -v pnpm >/dev/null 2>&1; then
    _stacks[pnpm]="pnpm install"
  elif [[ -f "$_wt/package.json" ]] && command -v npm >/dev/null 2>&1; then
    _stacks[npm]="npm install"
  fi
  if [[ -f "$_wt/uv.lock" ]] && command -v uv >/dev/null 2>&1; then
    _stacks[uv]="uv sync"
  fi
  if [[ -f "$_wt/go.mod" ]] && command -v go >/dev/null 2>&1; then
    _stacks[go]="go mod download"
  fi
  (( ${#_stacks[@]} == 0 )) && return 0
  local _name _cmd _slog
  for _name in ${(k)_stacks}; do
    _cmd=${_stacks[$_name]}
    _slog="$_wt/.gwt-postcreate.$_name.log"
    echo "gwt: $_name in bg ($_cmd) → tail -f $_slog"
    ( cd "$_wt" && eval "$_cmd" >"$_slog" 2>&1 ) &!
  done
}

# Create a new worktree at .worktrees/<branch> (slashes preserved), cd in,
# link env files, kick off dep install in the background.
function _gwt_create {
  local _branch="$1" _base="$2"
  local _main=$(_git_main_root) || _main="$_git_root"
  local _wt_path="$_main/.worktrees/$_branch"
  mkdir -p "${_wt_path:h}"
  local _base_ref=""
  [[ -n "$_base" ]] && _base_ref=$(_resolve_base "$_base")
  if [[ -n "$_base_ref" ]]; then
    git worktree add -b "$_branch" "$_wt_path" "$_base_ref" || return 1
  else
    git worktree add -b "$_branch" "$_wt_path" || return 1
  fi
  cd "$_wt_path" || return 1
  _gwt_link_files "$_main" "$_wt_path"
  _gwt_postcreate "$_wt_path" "$_main"
}

# Attach an existing branch to a new worktree at the canonical path.
function _gwt_attach {
  local _branch="$1"
  local _main=$(_git_main_root) || _main="$_git_root"
  local _wt_path="$_main/.worktrees/$_branch"
  mkdir -p "${_wt_path:h}"
  git worktree add "$_wt_path" "$_branch" || return 1
  cd "$_wt_path" || return 1
  _gwt_link_files "$_main" "$_wt_path"
  _gwt_postcreate "$_wt_path" "$_main"
}

# Interactive branch-name builder. Echoes final name on stdout; sets
# `_branch_base_out` to the chosen base. Returns 1 on cancel.
#   $1 initial token (may be empty); $2 default-base label for the prompt.
function _branch_wizard {
  local _initial="$1" _label="$2"
  local _name="$_initial"
  if [[ -z "$_name" ]]; then
    local _p="(Enter: branch name [Ticket: ABC-1234 || Tag: 4.3.21], Ctrl+C: cancel)> "
    [[ -n "$_label" ]] && _p="(Enter: new branch from $_label [Ticket: ABC-1234 || Tag: 4.3.21], Ctrl+C: cancel)> "
    _name=$(fzf --prompt="$_p" --height=1 --reverse --no-info --print-query </dev/null)
    [[ -z "$_name" ]] && return 1
  fi

  local _final=""
  local _tag_mask='^[0-9]+\.[0-9]+\.[0-9]+([-+].*)?$'
  if [[ $_name =~ $_tag_mask ]]; then
    _branch_base_out=$(_default_branch) || return 1
    _final="release/$_name"
  else
    local _prefix=$(echo -e "feature\nbugfix\nhotfix" |
      fzf --prompt="(Enter: select prefix)> " --height=3 --no-input --no-info)
    [[ -z "$_prefix" ]] && return 1

    if [[ "$_prefix" == "hotfix" ]]; then
      _branch_base_out=$(_pick_base_branch "(Enter: select base branch for hotfix)> ") || return 1
    else
      _branch_base_out=$(_default_branch) || return 1
    fi

    local _suffix=$(fzf --height=1 --reverse --no-info --print-query \
      --prompt="(Enter: select suffix)> " </dev/null)
    if [[ -n "$_suffix" ]]; then
      _suffix=${_suffix:l}
      _suffix=${_suffix// /-}
      _final="$_prefix/$_name-$_suffix"
    else
      _final="$_prefix/$_name"
    fi
  fi

  if ! git check-ref-format "refs/heads/$_final" 2>/dev/null; then
    echo "Invalid branch name: $_final" >&2
    return 1
  fi
  echo "$_final"
}

if are_binary git bat fzf; then
  function gcm {
    in_git_repo || return 1

    local initial_query="$*"

    local commit_prompt
    local _branch=$(git branch --show-current)
    local commit_prefix=""
    [[ $_branch =~ '([A-Z]+-[0-9]+)' ]] && commit_prefix=$match[1]
    if [[ -z "$commit_prefix" ]]; then
      commit_prompt="(Enter: commit message)> "
    else
      commit_prompt="(Enter: commit message [$commit_prefix])> "
    fi

    local commit_message=$(fzf --height=1 \
      --query="$initial_query" \
      --reverse \
      --no-info \
      --print-query \
      --prompt="$commit_prompt" </dev/null)

    if [[ -z "$commit_message" ]]; then
      return 0
    fi

    if [[ -z "$commit_prefix" ]]; then
      git commit -m "$commit_message"
    else
      git commit -m "$commit_prefix: $commit_message"
    fi
  }

  function gp {
    in_git_repo || return 1

    local -a banned_branches=(develop staging production master main)
    local branch_name=$(git branch --show-current)

    if (( ${banned_branches[(Ie)$branch_name]} )); then
      _confirm_destructive "[WARN] Protected Branch: Confirm Push" || return 0
    fi

    git push -u origin "$branch_name"
  }
  function gcr {
    in_git_repo || return 1

    local current_tag=${$(git tag --sort=version:refname)[-1]}
    local increment_action=$(printf 'Major\nMinor\nPatch\n' |
      fzf --prompt="(Enter: select action)> " \
        --height=4 \
        --no-input \
        --no-info)

    [[ $current_tag =~ '^([0-9]+)\.([0-9]+)\.([0-9]+)' ]]
    local major=$match[1]
    local minor=$match[2]
    local patch=$match[3]

    case $increment_action in
    "Major")
      major=$((major + 1))
      ;;
    "Minor")
      minor=$((minor + 1))
      ;;
    "Patch")
      patch=$((patch + 1))
      ;;
    *)
      return 0
      ;;
    esac
    local release_branch="$major.$minor.$patch"
    _checkout_branch_or_worktree "release/$release_branch" create
  }
  function gcb {
    in_git_repo || return 1

    local initial_query="${1:-}"
    _list_git_branches
    local git_branches=${(F)reply}

    # Fixed 3-item list + preview scaled to terminal height
    local _list_h=4 # prompt(1) + items(3)
    local _prev_h=$((${LINES:-40} * 50 / 100))
    local _gcb_out=$(echo "$git_branches" |
      fzf --prompt="(Enter: checkout branch, Ctrl+C: create new branch)> " \
        --query="$initial_query" \
        --bind 'enter:accept' \
        --exact \
        --select-1 \
        --exit-0 \
        --print-query \
        --no-info \
        --preview='git log --oneline --color=always -15 {} 2>/dev/null' \
        --preview-window="down:${_prev_h}:wrap:nohidden" \
        --height=$((_list_h + _prev_h)))
    local branch_name=${_gcb_out##*$'\n'}

    if [[ -n "$branch_name" && ${reply[(r)$branch_name]} == "$branch_name" ]]; then
      _checkout_branch_or_worktree "$branch_name"
      return 0
    fi

    local new_branch_name
    new_branch_name=$(_branch_wizard "$branch_name" "") || return 0
    _checkout_branch_or_worktree "$new_branch_name" create "$_branch_base_out"
  }

  function ga {
    in_git_repo || return 1

    if [[ -n "$@" ]]; then
      git add "$@"
    fi
    local temp_pwd="$PWD"
    cd "$_git_root"

    local git_status=$(git status --porcelain)
    local -a _tracked_arr=() _deleted_arr=() _untracked_arr=()
    local _gs_line _xy _rest
    while IFS= read -r _gs_line; do
      [[ -z $_gs_line ]] && continue
      _xy=${_gs_line:0:2}
      _rest=${_gs_line:3}
      if [[ $_xy == '??' ]]; then
        # Untracked: expand directories to files
        if [[ -d $_rest ]]; then
          _untracked_arr+=(${_rest}**/*(.N))
        else
          _untracked_arr+=("$_rest")
        fi
      elif [[ ${_xy:1:1} == D ]]; then
        # Working-tree deleted (second char D)
        _deleted_arr+=("$_rest")
      elif [[ ${_xy:1:1} == M ]]; then
        # Working-tree modified (second char M), includes MM and RM
        # Renamed entries: "RM old -> new" → take new name after " -> "
        if [[ $_rest == *' -> '* ]]; then
          _tracked_arr+=("${_rest##* -> }")
        else
          _tracked_arr+=("$_rest")
        fi
      fi
    done <<<"$git_status"
    _tracked_arr=(${(ou)_tracked_arr})
    local tracked_files=${(F)_tracked_arr}
    local deleted_files=${(F)_deleted_arr}
    local untracked_files=${(F)_untracked_arr}

    if [[ -n "$tracked_files" ]]; then
      local tracked_selected=$(printf "%s\n" $tracked_files | fzf --multi \
        --preview='git diff --diff-filter=M -- {} | bat --style=numbers --color=always' \
        --preview-window='up:90%:wrap:nohidden' \
        --prompt="(Tab: toggle file, Shift+Tab: toggle all files, Enter: submit selection, Ctrl+C: cancel selection)> " \
        --header="Add tracked files" \
        --bind 'shift-tab:toggle-all' \
        --bind "tab:toggle" \
        --bind 'enter:transform:[[ $FZF_SELECT_COUNT -gt 0 ]] && echo accept || echo abort' \
        --no-info \
        --exit-0)

      if [[ -n "$tracked_selected" ]]; then
        local -a tracked_selection=(${(f)tracked_selected})
        for file in "${tracked_selection[@]}"; do
          git add "$file" -p
        done
      fi
    fi

    if [[ -n "$deleted_files" ]]; then
      local deleted_selected=$(printf "%s\n" $deleted_files |
        fzf --multi \
          --preview='git diff --diff-filter=D -- {} | bat --style=numbers --color=always' \
          --preview-window='up:90%:wrap:nohidden' \
          --prompt="(Tab: toggle file, Shift+Tab: toggle all files, Enter: submit selection, Ctrl+C: cancel selection)> " \
          --header="Add deleted files" \
          --bind 'shift-tab:toggle-all' \
          --bind "tab:toggle" \
          --bind 'enter:transform:[[ $FZF_SELECT_COUNT -gt 0 ]] && echo accept || echo abort' \
          --no-info \
          --exit-0)

      if [[ -n "$deleted_selected" ]]; then
        local -a deleted_selection=(${(f)deleted_selected})
        for file in "${deleted_selection[@]}"; do
          git add "$file"
        done
      fi
    fi

    if [[ -n "$untracked_files" ]]; then
      local untracked_selected=$(printf "%s\n" $untracked_files |
        fzf --multi \
          --preview='bat --style=numbers --color=always {}' \
          --preview-window='up:90%:wrap:nohidden' \
          --prompt="(Tab: toggle file, Shift+Tab: toggle all files, Enter: submit selection, Ctrl+C: cancel selection)> " \
          --header="Add untracked files" \
          --bind 'shift-tab:toggle-all' \
          --bind "tab:toggle" \
          --bind 'enter:transform:[[ $FZF_SELECT_COUNT -gt 0 ]] && echo accept || echo abort' \
          --no-info \
          --exit-0)

      if [[ -n "$untracked_selected" ]]; then
        local -a untracked_selection=(${(f)untracked_selected})
        for file in "${untracked_selection[@]}"; do
          git add "$file"
        done
      fi
    fi
    cd "$temp_pwd"
    clear
    echo -e ""
    git status --short
  }

  function gsd {
    in_git_repo || return 1

    git diff
  }

  function gd {
    in_git_repo || return 1

    local initial_query="${1:-}"
    local current_branch=$(git branch --show-current)
    _list_git_branches
    local git_branches=${(F)reply}

    local _gd_out=$(echo "$git_branches" |
      fzf --prompt="(Enter: select comparison branch)> " \
        --query="$initial_query" \
        --select-1 \
        --exit-0 \
        --print-query \
        --no-info \
        --preview="git diff ${current_branch}..{} 2>/dev/null | bat --style=numbers --color=always -l diff" \
        --preview-window='up:90%:wrap:nohidden' \
        --height=50%)
    local remote_branch=${_gd_out##*$'\n'}

    if [[ -z "$remote_branch" ]]; then
      return 0
    fi

    git diff "$current_branch".."$remote_branch" --color | bat --style=numbers --color=always -l diff
  }

  function gcd {
    in_git_repo || return 1

    local initial_query="${1:-}"
    local current_branch=$(git branch --show-current)
    _list_git_branches
    local git_branches=${(F)reply}
    local _gcd_out=$(echo "$git_branches" |
      fzf --prompt="(Enter: select target branch for diff)> " \
        --query="$initial_query" \
        --select-1 \
        --exit-0 \
        --print-query \
        --no-info \
        --height=5)
    local target_branch=${_gcd_out##*$'\n'}

    if [[ -z "$target_branch" ]]; then
      return 0
    fi

    # Clean branch names for filename (remove remotes/origin/ prefix and special chars)
    local clean_current=${${current_branch#remotes/origin/}//\//-}
    local clean_target=${${target_branch#remotes/origin/}//\//-}
    local patch_file="${clean_current}--${clean_target}.diff"

    git diff $current_branch..$target_branch >"$patch_file"

    if [[ -f "$patch_file" ]]; then
      echo "✅ Patch file created: $patch_file"
    else
      echo "❌ Failed to create patch file"
      return 1
    fi
  }

  function gst {
    in_git_repo || return 1

    echo ""
    git status --short
  }
  function gg {
    in_git_repo || return 1

    local current_branch=$(git branch --show-current)
    git rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1 ||
      git branch --set-upstream-to="origin/$current_branch" 2>/dev/null
    git pull
  }
  function gga {
    in_git_repo || return 1

    local current_branch=$(git branch --show-current)
    git rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1 ||
      git branch --set-upstream-to="origin/$current_branch" 2>/dev/null
    git pull --all
  }
  function gf {
    in_git_repo || return 1

    git fetch
  }
  function gfa {
    in_git_repo || return 1

    git fetch --all
  }
  function ghr {
    in_git_repo || return 1
    _confirm_destructive "[WARN] Hard reset HEAD~ (drops last commit + working changes)" || return 0
    git reset --hard HEAD~
  }
  function ghrn {
    in_git_repo || return 1
    _confirm_destructive "[WARN] Hard reset HEAD~$1 (drops last $1 commits + working changes)" || return 0
    git reset --hard HEAD~"$1"
  }
  function gr {
    in_git_repo || return 1

    git reset --soft HEAD~
  }
  function grn {
    in_git_repo || return 1

    git reset --soft HEAD~"$1"
  }
  function gsa {
    in_git_repo || return 1

    git stash
  }
  # Confirm a destructive action via fzf Yes/No. Returns 0 on Yes, 1 otherwise.
  function _confirm_destructive {
    local choice=$(printf 'No\nYes\n' |
      fzf \
        --no-input \
        --header="$1" \
        --reverse \
        --height=4 \
        --no-info \
        --no-multi \
        --exit-0)
    [[ "$choice" == "Yes" ]]
  }

  function gw {
    in_git_repo || return 1
    [[ -z "$(git status --porcelain)" ]] && return 0
    _confirm_destructive "[WARN] Local Branch: Wipe Non-Pushed Changes" || return 0
    git stash push -u >/dev/null && git stash drop
  }

  function gwa {
    in_git_repo || return 1
    _confirm_destructive "[WARN] Local Branch: Wipe Non-Pushed Changes" || return 0
    git stash push -u >/dev/null
    git stash clear
  }

  function ggo {
    in_git_repo || return 1

    local initial_query="${1:-}"
    _list_git_branches
    local git_branches=${(F)reply}

    local selected_branch=$(echo -e "$git_branches" |
      fzf --prompt="(Enter: select branch to pull from origin)> " \
        --query="$initial_query" \
        --select-1 \
        --exit-0 \
        --no-info \
        --height=10)

    if [[ -n "$selected_branch" ]]; then
      git pull origin "$selected_branch"
    fi
  }
  function gl {
    in_git_repo || return 1

    local initial_query="${1:-}"
    local _commit_line=$(git log --oneline --color=always |
      fzf --ansi \
        --prompt="(Enter: show commit, Ctrl+C: cancel)> " \
        --query="$initial_query" \
        --no-sort \
        --exact \
        --exit-0 \
        --no-info \
        --preview='git show --stat --patch --color=always {1} 2>/dev/null | bat --style=numbers --color=always -l diff' \
        --preview-window='up:90%:wrap:nohidden' \
        --height=50%)
    local commit=${_commit_line%% *}

    if [[ -n "$commit" ]]; then
      git show --stat --patch --color=always "$commit" | bat --style=numbers --color=always -l diff
    fi
  }

  function gsp {
    in_git_repo || return 1

    local stash_list=$(git stash list)
    if [[ -z "$stash_list" ]]; then
      echo "No stashes found."
      return 0
    fi

    local selected=$(echo "$stash_list" |
      fzf --prompt="(Enter: pop stash, Ctrl+C: cancel)> " \
        --no-sort \
        --exit-0 \
        --no-info \
        --preview='line={}; git stash show -p --color=always "${line%%:*}" 2>/dev/null | bat --style=numbers --color=always -l diff' \
        --preview-window='up:90%:wrap:nohidden' \
        --height=50%)

    if [[ -z "$selected" ]]; then
      return 0
    fi

    local stash_ref=${selected%%:*}
    git stash pop "$stash_ref"
  }

  function gcp {
    in_git_repo || return 1

    local initial_query="${1:-}"
    local _selected=$(git log --oneline --color=always --all |
      fzf --ansi \
        --multi \
        --prompt="(Tab: toggle commit, Enter: cherry-pick selection, Ctrl+C: cancel)> " \
        --query="$initial_query" \
        --no-sort \
        --exit-0 \
        --no-info \
        --bind 'tab:toggle' \
        --bind 'shift-tab:toggle-all' \
        --preview='git show --stat --patch --color=always {1} 2>/dev/null | bat --style=numbers --color=always -l diff' \
        --preview-window='up:90%:wrap:nohidden' \
        --height=50%)

    if [[ -z "$_selected" ]]; then
      return 0
    fi

    # Extract hashes, reverse so oldest commit applies first (log is newest-first).
    # (Oa) = reverse-array order flag.
    local -a _lines=(${(f)_selected})
    local -a _hashes=("${_lines[@]%% *}")
    git cherry-pick "${(Oa)_hashes[@]}"
  }

fi

if are_binary git fzf; then
  function gwt {
    in_git_repo || return 1

    local _start_pwd="$PWD"

    # `gwt -` — toggle to the previously-visited worktree.
    if [[ "$1" == "-" ]]; then
      if [[ -z "$_GWT_LAST" || ! -d "$_GWT_LAST" ]]; then
        echo "gwt: no previous worktree"
        return 1
      fi
      cd "$_GWT_LAST" || return 1
      typeset -g _GWT_LAST="$_start_pwd"
      return 0
    fi

    {
    local current_worktree="$_git_root"
    local repo_root=$(_git_main_root) || repo_root="$current_worktree"

    # If we're leaving a clean linked worktree, remove it after the switch.
    local _prev_clean_worktree=""
    if _in_linked_worktree && [[ -z "$(git status --porcelain)" ]]; then
      _prev_clean_worktree="$current_worktree"
    fi

    local worktrees_dir="$repo_root/.worktrees"

    # Build worktree rows, sorted newest-first by HEAD commit timestamp.
    local occupied_branches=""
    local -a _wt_rows=()
    local _path _branch _ts
    while IFS=$'\t' read -r _path _branch; do
      occupied_branches+="$_branch"$'\n'
      [[ "$_path" == "$current_worktree" ]] && continue
      _ts=$(git -C "$_path" log -1 --format=%at HEAD 2>/dev/null)
      _ts=${_ts:-0}
      _wt_rows+=("$_ts"$'\t'"$_path"$'\t'"$_branch")
    done < <(_list_worktrees)
    _wt_rows=("${(@On)_wt_rows}")
    local worktree_entries=""
    local _row _rest
    for _row in "${_wt_rows[@]}"; do
      _rest=${_row#*$'\t'}
      _path=${_rest%%$'\t'*}
      _branch=${_rest#*$'\t'}
      worktree_entries+="$_path  $_branch"$'\n'
    done

    _list_git_branches
    local all_branches=${(F)reply}

    local available_branches
    if [[ -n "$occupied_branches" ]]; then
      local -a _occ=(${(f)occupied_branches})
      local -a _avail=()
      local _b
      while IFS= read -r _b; do
        [[ -z $_b ]] && continue
        [[ ${_occ[(r)$_b]} == "$_b" ]] || _avail+=("$_b")
      done <<<"$all_branches"
      available_branches=${(F)_avail}
    else
      available_branches="$all_branches"
    fi

    local display_list=""
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      local wt_path=${line%% *}
      local wt_branch=${line##* }
      local marker=""
      _worktree_is_dirty "$wt_path" && marker+="*"
      _worktree_has_unpushed "$wt_path" && marker+="!"
      [[ -n "$marker" ]] && marker=" $marker"
      display_list+="[worktree] $wt_branch$marker  →  $wt_path"$'\n'
    done <<<"$worktree_entries"

    while IFS= read -r branch; do
      [[ -z "$branch" ]] && continue
      display_list+="[branch]   $branch"$'\n'
    done <<<"$available_branches"

    if [[ -z "$display_list" ]]; then
      echo "No worktrees or available branches found."
      return 0
    fi

    # Fixed 3-item list + preview scaled to terminal height
    local _list_h=4 # prompt(1) + items(3)
    local _prev_h=$((${LINES:-40} * 50 / 100))
    local selected=$(echo "$display_list" |
      fzf --prompt="(Enter: switch/create worktree, Ctrl+C: cancel)> " \
        --print-query \
        --exit-0 \
        --no-info \
        --height=$((_list_h + _prev_h)) \
        --preview='
          line={}
          if [[ ${line%% *} == "[worktree]" ]]; then
            p=${line##*  →  }
            git -C "$p" log --oneline --color=always -10 2>/dev/null
          else
            b=${line#"[branch]   "}
            git log --oneline --color=always -10 "$b" 2>/dev/null
          fi
        ' \
        --preview-window="down:${_prev_h}:wrap:nohidden")

    local query=${selected%%$'\n'*}
    local match=${selected##*$'\n'}

    if [[ -z "$match" || "$match" == "$query" ]]; then
      if [[ -z "$query" ]]; then
        return 0
      fi
      local new_branch_name="$query"
      local base_branch=$(echo "$all_branches" |
        fzf --prompt="(Enter: select base branch for '$new_branch_name')> " \
          --select-1 \
          --exit-0 \
          --no-info \
          --height=30%)
      if [[ -z "$base_branch" ]]; then
        return 0
      fi
      _gwt_create "$new_branch_name" "$base_branch" || return 1
      _gwt_remove_if_clean "$_prev_clean_worktree"
      return 0
    fi

    local entry_type=${match%% *}

    if [[ "$entry_type" == "[worktree]" ]]; then
      local target_path=${match##*  →  }
      cd "$target_path" || return 1
    else
      local branch_name=${match#"[branch]   "}
      _gwt_attach "$branch_name" || return 1
    fi
    _gwt_remove_if_clean "$_prev_clean_worktree"
    } always {
      [[ "$PWD" != "$_start_pwd" ]] && typeset -g _GWT_LAST="$_start_pwd"
    }
  }

  function gwtd {
    in_git_repo || return 1

    local target="$1"
    local repo_root=$(_git_main_root) || repo_root="$_git_root"

    local linked_worktrees=""
    local _path _branch
    while IFS=$'\t' read -r _path _branch; do
      [[ "$_path" == "$repo_root" ]] && continue
      local _marker=""
      _worktree_is_dirty "$_path" && _marker+="*"
      _worktree_has_unpushed "$_path" && _marker+="!"
      [[ -n "$_marker" ]] && _marker=" $_marker"
      linked_worktrees+="$_branch$_marker  →  $_path"$'\n'
    done < <(_list_worktrees)

    if [[ -z "$linked_worktrees" ]]; then
      echo "No linked worktrees found."
      return 0
    fi

    local selected=""
    if [[ -n "$target" ]]; then
      local _entry
      while IFS= read -r _entry; do
        local _ebranch=${_entry%%  →  *}
        local _ebranch_clean="$_ebranch"
        _ebranch_clean=${_ebranch_clean% \*\!}
        _ebranch_clean=${_ebranch_clean% \!}
        _ebranch_clean=${_ebranch_clean% \*}
        local _epath=${_entry##*  →  }
        if [[ "$_ebranch_clean" == "$target" || "$_epath" == "$target" ]]; then
          selected="$_entry"
          break
        fi
      done <<<"$linked_worktrees"
    else
      selected=$(echo "$linked_worktrees" |
        fzf --prompt="(Enter: select worktree to remove)> " \
          --select-1 \
          --exit-0 \
          --no-info \
          --height=10)
    fi

    if [[ -z "$selected" ]]; then
      return 0
    fi

    local worktree_path=${selected##*  →  }

    if [[ "$PWD" == "$worktree_path"* ]]; then
      cd "$repo_root" || return 1
    fi

    local -a _msgs=()
    _worktree_is_dirty "$worktree_path" && _msgs+=("uncommitted changes")
    _worktree_has_unpushed "$worktree_path" && _msgs+=("unpushed commits")
    if (( ${#_msgs[@]} )); then
      local _why=${(j:, :)_msgs}
      _confirm_destructive "[WARN] Worktree '$worktree_path' has $_why — destroy?" || return 0
      git worktree remove --force "$worktree_path" || return 1
    else
      git worktree remove "$worktree_path" || return 1
    fi
    git worktree prune --expire now >/dev/null 2>&1

    # Clean up empty parent dirs inside .worktrees/ (e.g. feature/ after
    # removing feature/foo).
    local _wt_root="$repo_root/.worktrees"
    local _parent="${worktree_path:h}"
    while [[ "$_parent" == "$_wt_root"/* ]]; do
      rmdir "$_parent" 2>/dev/null || break
      _parent="${_parent:h}"
    done
  }

  # Wizard like gcb, but always creates a worktree off the default branch.
  function gcbw {
    in_git_repo || return 1

    local default_branch
    default_branch=$(_default_branch) || {
      echo "Could not determine default branch"
      return 1
    }

    local new_branch_name
    new_branch_name=$(_branch_wizard "${1:-}" "$default_branch") || return 0

    local _existing_wt=$(_worktree_path_for_branch "$new_branch_name")
    if [[ -n "$_existing_wt" ]]; then
      cd "$_existing_wt" || return 1
      echo "Switched to existing worktree: $_existing_wt"
      return 0
    fi

    if git rev-parse --verify --quiet "refs/heads/$new_branch_name" >/dev/null 2>&1; then
      echo "Branch '$new_branch_name' already exists but is not in a worktree"
      return 1
    fi

    _gwt_create "$new_branch_name" "$_branch_base_out"
  }
fi

function view_git_file {
  local _url="${1//github.com/raw.githubusercontent.com}"
  _url="${_url//\/blob\//\/refs\/heads\/}"
  if is_binary bat; then
    curl -s "$_url" | bat -f -l "${1##*\.}"
  else
    curl -s "$_url"
  fi
}

