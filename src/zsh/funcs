      available_branches=${(F)_avail}
    else
      available_branches="$all_branches"
    fi

    local display_list=""
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      local wt_path=${line%% *}
      local wt_branch=${line##* }
      local marker=""
      _worktree_is_dirty "$wt_path" && marker+="*"
      _worktree_has_unpushed "$wt_path" && marker+="!"
      [[ -n "$marker" ]] && marker=" $marker"
      display_list+="[worktree] $wt_branch$marker  →  $wt_path"$'\n'
    done <<<"$worktree_entries"

    while IFS= read -r branch; do
      [[ -z "$branch" ]] && continue
      display_list+="[branch]   $branch"$'\n'
    done <<<"$available_branches"

    # Empty list (e.g. fresh repo with only the current branch) → skip fzf
    # and fall through to the create path so the wizard still runs. Size
    # the window exactly to the visible row count (capped at 3) + separator
    # + prompt; fzf's `~` adaptive height reserves an extra slot we don't want.
    local _max_items=3
    local selected=""
    if [[ -n "$display_list" ]]; then
      local -a _dl=(${(f)display_list})
      local _n=${#_dl[@]}
      (( _n > _max_items )) && _n=$_max_items
      selected=$(echo "$display_list" |
        fzf --prompt="(Enter: switch/create, Ctrl+C: wizard)> " \
          --print-query \
          --exit-0 \
          --no-info \
          --query="${*:-}" \
          --height=$((_n + 2)))
    fi

    local query=$(_trim_ws "${selected%%$'\n'*}")
    local match=$(_trim_ws "${selected##*$'\n'}")

    # No match (typed-new OR Ctrl+C) → enter create path. Names that already
    # contain a slash (e.g. `feature/foo`, `release/1.2.3`) are taken as-is
    # and we just ask for a base. Bare names (or empty, from Ctrl+C) route
    # through `_branch_wizard` to enforce the feature/bugfix/hotfix/release
    # prefix convention.
    if [[ -z "$match" || "$match" == "$query" ]]; then
      local _new_name="$query" _base=""
      if [[ "$_new_name" == */* ]]; then
        if [[ "$_new_name" == hotfix/* ]]; then
          _base=$(_pick_base_branch "(Enter: select base branch for '$_new_name')> ") || return 0
        else
          _base=$(_default_branch) || return 0
        fi
      else
        local _wiz_out
        _wiz_out=$(_branch_wizard "$_new_name" "") || return 0
        IFS=$'\t' read -r _new_name _base <<<"$_wiz_out"
      fi
      # Wizard may have produced an already-existing branch — handle the
      # swap-to-existing case the same way `_checkout_branch_or_worktree`
      # does, so the wizard never silently re-creates.
      local _existing_wt=$(_worktree_path_for_branch "$_new_name")
      if [[ -n "$_existing_wt" && "$_existing_wt" != "$_git_root" ]]; then
        cd "$_existing_wt" || return 1
        echo "Switched to existing worktree: $_existing_wt"
        _gwt_remove_if_clean "$_prev_clean_worktree"
        return 0
      fi
      if git rev-parse --verify --quiet "refs/heads/$_new_name" >/dev/null 2>&1; then
        _gwt_attach "$_new_name" || return 1
      else
        _gwt_create "$_new_name" "$_base" || return 1
      fi
      _gwt_remove_if_clean "$_prev_clean_worktree"
      return 0
    fi

    local entry_type=${match%% *}

    if [[ "$entry_type" == "[worktree]" ]]; then
      local target_path=${match##*  →  }
      cd "$target_path" || return 1
    else
      local branch_name=${match#"[branch]   "}
      _gwt_attach "$branch_name" || return 1
    fi
    _gwt_remove_if_clean "$_prev_clean_worktree"
    } always {
      [[ "$PWD" != "$_start_pwd" ]] && typeset -g _GWT_LAST="$_start_pwd"
    }
  }

  function gwtd {
    in_git_repo || return 1

    local target="$1"
    local repo_root=$(_git_main_root) || repo_root="$_git_root"

    local linked_worktrees=""
    local _path _branch
    while IFS=$'\t' read -r _path _branch; do
      [[ "$_path" == "$repo_root" ]] && continue
      local _marker=""
      _worktree_is_dirty "$_path" && _marker+="*"
      _worktree_has_unpushed "$_path" && _marker+="!"
      [[ -n "$_marker" ]] && _marker=" $_marker"
      linked_worktrees+="$_branch$_marker  →  $_path"$'\n'
    done < <(_list_worktrees)

    if [[ -z "$linked_worktrees" ]]; then
      echo "No linked worktrees found."
      return 0
    fi

    local selected=""
    if [[ -n "$target" ]]; then
      local _entry
      while IFS= read -r _entry; do
        local _ebranch=${_entry%%  →  *}
        local _ebranch_clean="$_ebranch"
        _ebranch_clean=${_ebranch_clean% \*\!}
        _ebranch_clean=${_ebranch_clean% \!}
        _ebranch_clean=${_ebranch_clean% \*}
        local _epath=${_entry##*  →  }
        if [[ "$_ebranch_clean" == "$target" || "$_epath" == "$target" ]]; then
          selected="$_entry"
          break
        fi
      done <<<"$linked_worktrees"
    else
      selected=$(echo "$linked_worktrees" |
        fzf --prompt="(Enter: select worktree to remove)> " \
          --select-1 \
          --exit-0 \
          --no-info \
          --height=~10)
    fi

    if [[ -z "$selected" ]]; then
      return 0
    fi

    local worktree_path=${selected##*  →  }

    if [[ "$PWD" == "$worktree_path"* ]]; then
      cd "$repo_root" || return 1
    fi

    local -a _msgs=()
    _worktree_is_dirty "$worktree_path" && _msgs+=("uncommitted changes")
    _worktree_has_unpushed "$worktree_path" && _msgs+=("unpushed commits")
    # Always pass --force to treeman: this fn's own dirty/unpushed
    # checks already gate at the .git-status-porcelain level (which
    # respects .gitignore), and the confirmation prompt above guards
    # the dirty case. Without --force, `git worktree remove` refuses
    # on ANY untracked file including gitignored build artifacts —
    # vendor/, node_modules/, .treeman-hooks/ — which is the wrong
    # default for a worktree the user just asked to destroy.
    if (( ${#_msgs[@]} )); then
      local _why=${(j:, :)_msgs}
      _confirm_destructive "Worktree '$worktree_path' has $_why — destroy?" || return 0
    fi
    # Don't pass --foreground: that bypasses the daemon RPC and runs
    # predelete + db teardown + `git worktree remove --force` synchronously
    # in this shell. For a Laravel checkout that means rm -rf on a
    # 250k-file vendor/+node_modules/ tree plus N DROP DATABASE roundtrips
    # in the foreground — which is exactly the gwtd-hangs / system-lag
    # path we just hit. Daemon handles it in the background.
    treeman wt delete "$worktree_path" --yes --repo "$repo_root" --force || return 1
    # Empty-parent cleanup (e.g. `.worktrees/feature/` after removing
    # `feature/foo`) is now handled inside `treeman wt delete` —
    # synchronously on the foreground path, daemon-side on the async
    # teardown path. No shell-side rmdir loop needed.
  }

  # cd back to the main repo root (the non-worktree checkout). From a linked
  # worktree this exits to main; from a subdir of any worktree it surfaces to
  # that checkout's root. The worktree itself is left intact — pair with gwtd
  # if you also want to remove it. Delegates to `treeman wt back` so the
  # main-repo path comes from treeman's registry (no `git rev-parse` round-trip).
  function gwte {
    in_git_repo || { echo "gwte: not in a git repo"; return 1; }
    local _main
    _main=$(_git_main_root) || { echo "gwte: cannot determine main repo root"; return 1; }
    [[ "$PWD" == "$_main" ]] && return 0
    local _start_pwd="$PWD"
    local _was_wt=0
    _in_linked_worktree && _was_wt=1
    local _out _dest
    _out=$(treeman wt back 2>/dev/null) || _out=""
    _dest=${_out%%$'\n'*}
    [[ -z "$_dest" ]] && _dest="$_main"
    cd "$_dest" || return 1
    (( _was_wt )) && typeset -g _GWT_LAST="$_start_pwd"
  }

  # Like gwte (cd to main repo root from a linked worktree) but also removes
  # the worktree we just exited. Skips silently when the worktree has
  # uncommitted changes or unpushed commits — never destroys work.
  # Delegates removal to `treeman wt back --remove` (runs predelete hooks,
  # tears down per-worktree DB state, then `git worktree remove`).
  # Non-interactive (no tty on stdin, e.g. Claude Code SessionEnd hook)
  # also skips the cd-to-main so the calling shell isn't disturbed.
  function gwtc {
    in_git_repo || { echo "gwtc: not in a git repo"; return 1; }
    local _main
    _main=$(_git_main_root) || { echo "gwtc: cannot determine main repo root"; return 1; }
    if [[ "$_main" == "$_git_root" ]]; then
      echo "gwtc: not in a linked worktree — nothing to clean"
      return 1
    fi
    local _wt="$_git_root"

    local -a _msgs=()
    _worktree_is_dirty "$_wt" && _msgs+=("uncommitted changes")
    _worktree_has_unpushed "$_wt" && _msgs+=("unpushed commits")
    if (( ${#_msgs[@]} )); then
      if [[ -t 0 ]]; then
        local _why=${(j:, :)_msgs}
        echo "gwtc: keeping '$_wt' ($_why)"
      fi
      return 0
    fi

    # `treeman wt back --remove` rechecks dirty+unpushed itself and prints
    # the main path on stdout line 1, then a status line ("ok: queued: …")
    # on line 2. The teardown is detached by the daemon so the foreground
    # shell returns immediately. Take just the path.
    #
    # `--force` is passed because we already gated on dirty/unpushed at
    # the porcelain-status level above; without it the underlying `git
    # worktree remove` refuses on gitignored build artifacts (vendor/,
    # node_modules/, .treeman-hooks/) and gwtc fails on every
    # post-composer / post-yarn worktree.
    local _out _dest
    _out=$(treeman wt back --remove --force) || return 1
    _dest=${_out%%$'\n'*}
    cd "$_dest" || return 1
    # Empty-parent cleanup (e.g. `.worktrees/feature/` after removing
    # `feature/foo`) is handled inside treeman's teardown path.
  }
fi

