#!/usr/bin/env zsh

# Source of truth for the plugin list. The shell-side `manager` and the
# host-side `zsh-plugin-updater.nix` both consume this array.
# typeset -a (not `local`) so the file works at top-level scope when
# sourced by the non-interactive updater (`zsh -c 'source plugins; ...'`).
# Inside a function (interactive shell init) typeset still scopes locally.
typeset -a plugins=(
  "Aloxaf/fzf-tab"
  "zsh-users/zsh-autosuggestions"
  "stubbedev/zsh-fzf-artisan"
  "stubbedev/zsh-fzf-npm-run"
  "softmoth/zsh-vim-mode"
  "zdharma/fast-syntax-highlighting"
)

# Side-effect (clone-on-demand + source) only fires for interactive TTY
# sessions. Non-interactive `zsh -c` callers (the systemd updater) get the
# array declared above without running the manager.
if [[ -o interactive ]] && [[ -t 0 ]]; then
  source_github_plugins $plugins "$HOME/.stubbe/src/zsh/plugins.d"
fi
