#!/usr/bin/env zsh
# shellcheck disable=SC1091

function is_binary {
  command -v "$1" &>/dev/null
}

function is_nix {
  [[ -r /etc/os-release ]] || return 1
  local content=$(<"/etc/os-release")
  [[ "$content" == *$'\n'ID=nixos* ]] || [[ "$content" == ID=nixos* ]]
}

function are_binary {
  for arg in "$@"; do
    if ! is_binary "$arg"; then
      return 1
    fi
  done
  return 0
}

function is_directory {
  [[ -d "$1" ]]
}

function are_directory {
  for arg in "$@"; do
    if ! is_directory "$arg"; then
      return 1
    fi
  done
  return 0
}


function is_file {
  [[ -f "$1" ]]
}

function are_file {
  for arg in "$@"; do
    if ! is_file "$arg"; then
      return 1
    fi
  done
  return 0
}

function has_string {
  [[ -r "$1" ]] || return 1
  local content=$(<"$1")
  [[ "$content" == *"$2"* ]]
}

function is_elevated_shell {
  [[ "$EUID" -eq 0 ]]
}

function src_zsh {
  is_file "$HOME/.zshrc" && source "$HOME/.zshrc"
}
