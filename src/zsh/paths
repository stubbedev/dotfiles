#!/usr/bin/env zsh
# EXPAND LIST WITH DESIRED PATHS

STUBBE_PATHS=(
  "$HOME/.nix-profile/bin"
  "$HOME/.stubbe/bin"
  "$HOME/.stubbe/src/go/bin"
  "$HOME/.stubbe/src/go/packages/bin"
  "$HOME/.stubbe/src/aerc/scripts"
  "$HOME/.local/bin"
  "$HOME/.config/composer/vendor/bin"
  "$HOME/.config/emacs/bin"
  "$HOME/.bun/bin"
  "$HOME/.volta/bin"
  "$HOME/.local/share/nvim/mason/bin"
  "$HOME/.opencode/bin"
  "$HOME/.cargo/bin"
  "$HOME/.deno/bin"
  "$HOME/.go/bin"
  "$HOME/go/bin"
  "$HOME/bin"
  "$HOME/.pyenv/bin"
  "/sbin"
)

local p
local -a new_paths=()
for p in "${STUBBE_PATHS[@]}"; do
  [[ -d "$p" ]] || continue
  [[ ":$PATH:" == *":$p:"* ]] && continue
  new_paths+=("$p")
done
(( ${#new_paths} )) && PATH="${(j/:/)new_paths}:$PATH"
export PATH
