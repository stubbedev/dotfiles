#!/usr/bin/env zsh

function _settings_init {
  bindkey "^Xa" _expand_alias
  bindkey -s "^[R" "src_zsh^M"
  bindkey -s "^[o" "nvim^M"
  bindkey -s "^[O" "nvim .^M"
  function _git_shorthand_descriptions {
    (( CURRENT != 1 )) && return 1
    (( ${#_git_shorthand_docs} == 0 )) && return 1

    local -a git_cmds
    local func
    for func in "${(@k)_git_shorthand_docs}"; do
      git_cmds+=("${func}:${_git_shorthand_docs[$func]}")
    done

    _describe -t git-shortcuts 'git shortcuts' git_cmds
  }

  zstyle ':completion:*' completer _expand _expand_alias _git_shorthand_descriptions _complete _ignored
  zstyle ':completion:*' fzf-tab true
  zstyle ':completion:*' complete-options true
  zstyle ':completion:*' complete-aliases true
  zstyle ':completion:*' regular true
  zstyle ':completion:*' sort false
  zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'

  # disable sort when completing `git checkout`
  zstyle ':completion:*:git-checkout:*' sort false
  # set descriptions format to enable group support
  zstyle ':completion:*:descriptions' format '[%d]'
  # set list-colors to enable filename colorizing
  zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
  # force zsh not to show completion menu, which allows fzf-tab to capture the unambiguous prefix
  zstyle ':completion:*' menu no
  if is_binary eza; then
      zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
  fi
  zstyle ':fzf-tab:*' fzf-flags --color=fg:1,fg+:2 --bind=tab:accept --height=40% --reverse --info=inline
  zstyle ':fzf-tab:*' switch-group '<' '>'
  zstyle ':fzf-tab:*' fuzzy-search true

  # Add avahi-discovered .local hosts to ssh-style completion. avahi-browse
  # takes ~1.5s, so we serve from a stale on-disk cache and refresh in the
  # background — completion never blocks. The service-type filter excludes
  # Sonos boxes, printers, etc. so only ssh-able machines show up.
  if is_binary avahi-browse; then
    function _avahi_ssh_hosts {
      local cache="${XDG_CACHE_HOME:-$HOME/.cache}/zsh-avahi-hosts"
      local max_age=30
      local mtime
      mtime=$(stat -c %Y -- "$cache" 2>/dev/null || echo 0)
      if (( EPOCHSECONDS - mtime > max_age )); then
        {
          mkdir -p -- "${cache:h}"
          local tmp="$cache.$$"
          if avahi-browse -atrp 2>/dev/null \
               | awk -F';' '$1=="=" && $3=="IPv4" && ($5=="_workstation._tcp" || $5 ~ /ssh/) && $7!="" {print $7}' \
               | sort -u > "$tmp" 2>/dev/null; then
            mv -- "$tmp" "$cache"
          else
            rm -f -- "$tmp"
          fi
        } &!
      fi
      if [[ -s $cache ]]; then
        reply=( ${(f)"$(<$cache)"} )
      else
        reply=()
      fi
    }
    zstyle -e ':completion:*:hosts' hosts '_avahi_ssh_hosts'
  fi

  HYPHEN_INSENSITIVE=false
  DISABLE_AUTO_TITLE=true
  ENABLE_CORRECTION=true
  VIM_MODE_NO_DEFAULT_BINDINGS=true
  ARTISAN_OPEN_ON_MAKE_EDITOR=nvim
  HISTFILE="$HOME/.zsh_history"
  HISTTIMEFORMAT="[%F %T] "
  SAVEHIST=10000
  HISTSIZE=10000
  ZSH_FZF_HISTORY_SEARCH_BIND='^r'

  setopt APPEND_HISTORY
  setopt SHARE_HISTORY
  setopt EXTENDED_HISTORY
  setopt HIST_IGNORE_ALL_DUPS
  setopt COMPLETE_ALIASES

  bindkey -s "^[A" "tmux-lazy-docker^M"
  bindkey -s "^[t" "tmux-new-session^M"
  bindkey -s "^[g" "tmux-lazy-git^M"
  bindkey -s "^[a" "tmux-system-monitor^M"
  bindkey -s "^[h" "tmux-claude^M"

  local _cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}"

  if is_binary fzf; then
      bindkey -s "^[f" "tmux-pick-project^M"
      bindkey -s "^[F" "fzf-project-picker^M"
      bindkey -s "^[d" "tmux-pick-session^M"
      bindkey -s "^[D" "fzf-directory-picker^M"
      # Strip fzf's default `bindkey '^I'` (Tab) line so fzf-tab keeps Tab.
      function _settings_gen_fzf_init {
        local _out
        _out=$(fzf --zsh 2>/dev/null) || return 1
        print -r -- "${(F)${(f)_out:#bindkey '^I'*}}"
      }
      _cached_eval "$_cache_dir/fzf_init.zsh" "${commands[fzf]:A}" _settings_gen_fzf_init
      unfunction _settings_gen_fzf_init
  fi

  if is_binary starship && ! type starship_zle-keymap-select >/dev/null; then
      function _settings_gen_starship_init { starship init zsh; }
      _cached_eval "$_cache_dir/starship_init.zsh" "${commands[starship]:A}" _settings_gen_starship_init
      unfunction _settings_gen_starship_init
  fi

  # direnv hook. Required for `denv on` to actually export .env vars
  # into the shell — without this precmd hook, `direnv allow` just
  # writes the auth file but no subsequent prompt evaluates
  # `direnv export zsh`, so $VARS stay unset.
  #
  # The chatty "direnv: loading …" + "direnv: export +FOO +BAR …" lines
  # aren't controlled by DIRENV_LOG_FORMAT (hardcoded in `direnv export`
  # itself in 2.37.1), so we wrap the upstream hook to filter stderr
  # through grep. Real errors (`direnv: error …`, blocked .envrc, parse
  # errors) still pass through.
  if is_binary direnv && ! (( $+functions[_direnv_hook] )); then
      function _settings_gen_direnv_init { direnv hook zsh; }
      _cached_eval "$_cache_dir/direnv_init.zsh" "${commands[direnv]:A}" _settings_gen_direnv_init
      unfunction _settings_gen_direnv_init
      if (( $+functions[_direnv_hook] )); then
          # The "loading" / "export" lines are prefixed with an ANSI
          # color reset (\x1b[0m / \x1b[2m), so a `^direnv:` anchor
          # misses them. Plain substring match catches both colored and
          # plain output. Real errors (`direnv: error …`) pass through.
          function _direnv_hook {
              trap -- '' SIGINT
              eval "$(direnv export zsh 2> >(grep --line-buffered -vE 'direnv: (loading|export) ' >&2))"
              trap - SIGINT
          }
      fi
  fi

  if is_binary pyenv; then
      export PYENV_ROOT="$HOME/.pyenv"
      [[ ":$PATH:" == *":$PYENV_ROOT/bin:"* ]]    || PATH="$PYENV_ROOT/bin:$PATH"
      [[ ":$PATH:" == *":$PYENV_ROOT/shims:"* ]] || PATH="$PYENV_ROOT/shims:$PATH"
      function pyenv {
          unfunction pyenv
          eval "$(command pyenv init -)"
          eval "$(command pyenv virtualenv-init -)"
          pyenv "$@"
      }
  fi
}
_settings_init
unfunction _settings_init
