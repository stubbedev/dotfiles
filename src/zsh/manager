#!/usr/bin/env zsh

# Only run plugin management in interactive TTY sessions
if [[ ! -o interactive ]] || [[ ! -t 0 ]]; then
  return 0
fi

function source_github_plugins {
  # Disable job control to suppress background job messages
  setopt local_options no_notify no_monitor

  local -a args=("$@")
  local parent_dir=${args[-1]}
  local -a urls=("${args[@]:0:${#args[@]}-1}")
  [[ -d "$parent_dir" ]] || mkdir -p "$parent_dir"

  # Canonicalize once: derive (full_url, repo_name, target_path) per entry.
  local -a full_urls=() repos=() targets=()
  local _u
  for _u in $urls; do
    [[ $_u == http* ]] || _u="https://github.com/$_u"
    full_urls+=("$_u")
    repos+=("${_u:t:r}")
    targets+=("$parent_dir/${_u:t:r}")
  done

  # Remove directories that aren't in the expected list
  local existing_dir existing_repo
  for existing_dir in "$parent_dir"/*(/N); do
    existing_repo="${existing_dir:t}"
    if [[ ${repos[(r)$existing_repo]} != "$existing_repo" ]]; then
      print -P "%F{red}REMOVING: $existing_repo%f"
      rm -rf "$existing_dir"
    fi
  done

  # Clone any missing plugins in background; defer tmpdir until actually needed
  local tmpdir=""
  local -a pids=() tmpfiles=()
  local _i
  for (( _i = 1; _i <= ${#urls}; _i++ )); do
    if [[ ! -d "${targets[$_i]}" ]]; then
      [[ -n "$tmpdir" ]] || tmpdir=$(mktemp -d)
      local out="$tmpdir/${repos[$_i]}.out"
      tmpfiles+=("$out")
      (
        print -P "%F{green}ADDING: ${repos[$_i]}%f"
        git clone "${full_urls[$_i]}.git" "${targets[$_i]}" >/dev/null 2>&1
      ) >"$out" 2>&1 &
      pids+=($!)
    fi
  done

  (( ${#pids} )) && wait "${pids[@]}" 2>/dev/null

  local tmp
  for tmp in $tmpfiles; do
    [[ -f "$tmp" ]] && cat "$tmp"
  done
  [[ -n "$tmpdir" ]] && rm -rf "$tmpdir"

  # Source plugin files in the foreground after all jobs are done
  local target plugin_file
  for target in $targets; do
    [[ -d "$target" ]] || continue
    for plugin_file in $target/*.plugin.zsh(.N); do
      source "$plugin_file"
    done
  done
}
