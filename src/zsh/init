#!/usr/bin/env zsh

if [[ -d "$HOME/.stubbe" ]]; then
  function _stubbe_init {
    [[ -f "$HOME/.zsh_history" ]] || touch "$HOME/.zsh_history"
    local STBDIR="$HOME/.stubbe/src/zsh"
    local zcompdump="${ZDOTDIR:-$HOME}/.zcompdump"
    local -a pre=(paths fpaths apaths sysfuncs manager funcs)
    local -a post=(aliases plugins env settings)
    local f

    for f in "${pre[@]}"; do
      [[ -f "$STBDIR/$f" ]] && source "$STBDIR/$f"
    done

    autoload -Uz compinit
    [[ -f $zcompdump ]] && compinit -C -d "$zcompdump" || compinit -d "$zcompdump"

    for f in "${post[@]}"; do
      [[ -f "$STBDIR/$f" ]] && source "$STBDIR/$f"
    done
  }
  _stubbe_init
  unfunction _stubbe_init
fi
