#!/usr/bin/env zsh

# Prepend our completion dirs so generated completions (`_gh`, `_uv`, …)
# beat any same-named function shipped via $fpath defaults. Both candidate
# profile locations are listed; zsh ignores fpath entries whose dir doesn't
# exist at compinit time, so the unused one costs nothing.
function _fpaths_init {
  local dir="$HOME/.stubbe/src/zsh/fpaths.d"
  local default_dir="$HOME/.stubbe/src/zsh/fpaths.default.d"
  [[ -d "$dir" ]] || mkdir -p "$dir"
  [[ -d "$default_dir" ]] || mkdir -p "$default_dir"
  fpath=(
    "$default_dir"
    "$dir"
    "$HOME/.nix-profile/share/zsh/site-functions"
    "/etc/profiles/per-user/$USER/share/zsh/site-functions"
    $fpath
  )
}
_fpaths_init
unfunction _fpaths_init
