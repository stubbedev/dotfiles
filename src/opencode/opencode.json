{
	"$schema": "https://opencode.ai/config.json",
	"autoupdate": false,
	"watcher": {
		"ignore": ["node_modules/**", "dist/**", ".git/**"]
	},
	"formatter": false,
	"plugin": [
		"opencode-vibeguard",
		"@franlol/opencode-md-table-formatter@latest"
	],
	"mcp": {
		"chrome-devtools": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"chrome-devtools-mcp@latest",
				"--no-usage-statistics",
				"--executable-path",
				"@CHROME_EXECUTABLE@"
			]
		},
		"firefox-devtools": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"firefox-devtools-mcp@latest",
				"--firefox-path",
				"@FIREFOX_EXECUTABLE@"
			]
		},
		"atlassian-mcp": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"@stubbedev/atlassian-mcp@latest"
			]
		},
		"sentry-mcp": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"@stubbedev/sentry-mcp@latest"
			]
		},
		"jenkins-mcp": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"@stubbedev/jenkins-mcp@latest"
			]
		},
		"nix-mcp": {
			"type": "local",
			"command": [
				"uvx",
				"mcp-nixos"
			]
		},
		"logseq-mcp": {
			"type": "local",
			"command": [
				"uv",
				"run",
				"--with",
				"mcp-logseq",
				"mcp-logseq"
			],
			"environment": {
				"LOGSEQ_API_TOKEN": "logseq",
				"LOGSEQ_API_URL": "http://localhost:12315"
			}
		}
	},
	"instructions": ["~/.stubbe/src/opencode/plugin/shell-strategy/INFO.md"]
}
