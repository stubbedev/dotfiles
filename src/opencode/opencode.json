{
	"$schema": "https://opencode.ai/config.json",
	"autoupdate": false,
	"watcher": {
		"ignore": ["node_modules/**", "dist/**", ".git/**"]
	},
	"formatter": false,
	"plugin": [
		"opencode-vibeguard",
		"@franlol/opencode-md-table-formatter@latest"
	],
	"mcp": {
		"chrome-devtools": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"chrome-devtools-mcp@latest",
				"--no-usage-statistics",
				"--autoConnect"
			]
		},
		"atlassian-mcp": {
			"enabled": false,
			"type": "local",
			"command": ["npx", "-y", "@stubbedev/atlassian-mcp"]
		}
	},
	"instructions": ["~/.stubbe/src/opencode/plugin/shell-strategy/INFO.md"]
}
