{
	"$schema": "https://opencode.ai/config.json",
	"autoupdate": false,
	"watcher": {
		"ignore": ["node_modules/**", "dist/**", ".git/**"]
	},
	"formatter": false,
	"plugin": [
		"opencode-vibeguard",
		"@franlol/opencode-md-table-formatter@latest"
	],
	"mcp": {
		"atlassian": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"@stubbedev/atlassian-mcp@latest"
			]
		}
	},
	"instructions": ["~/.stubbe/src/opencode/plugin/shell-strategy/INFO.md"]
}
