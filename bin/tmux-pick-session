#!/usr/bin/env zsh

# `tmux list-sessions` exits non-zero (and prints to stderr) when no
# server is running. We can't pre-check with `pgrep tmux` because pgrep
# matches by truncated comm name (15 chars): this script's own comm
# is `tmux-pick-sessi` which substring-matches "tmux", so pgrep would
# falsely report a running server and the subsequent connect would fail.
SESSIONS=$(tmux list-sessions -F "#{session_name}" 2>/dev/null) || {
  clear
  exit 0
}

if [[ -z $SESSIONS ]]; then
  exit 0
fi

# Use fzf to select a session
SELECTED_SESSION=$(echo "$SESSIONS" | fzf --prompt="select tmux session: ")

# Check if a session was selected
if [[ -n $SELECTED_SESSION ]]; then
  # Attach to the selected session
  tmux attach-session -t "$SELECTED_SESSION"
else
  exit 0
fi
