#!/usr/bin/env zsh

SELECTED=$(fzf-pick-project "$*")

if [[ -z $SELECTED ]]; then
  exit 0
fi

SELECTED_NAME=$(basename "$SELECTED" | tr '.' '_')
TMUXCLIENTNAME="$(whoami)($SELECTED_NAME)"
# `tmux has-session` (no -t) succeeds iff the server is running.
# pgrep tmux substring-matches our own comm (`tmux-pick-proje`,
# truncated to 15 chars) and would falsely report a server, so the
# new-session call below would race against tmux start-up.
if ! tmux has-session 2>/dev/null; then
  TMUX_RUNNING=""
else
  TMUX_RUNNING=1
fi

if [[ -z $TMUX ]] && [[ -z $TMUX_RUNNING ]]; then
  tmux new-session -ds "$TMUXCLIENTNAME" -c "$SELECTED"
fi

if ! tmux has-session -t="$TMUXCLIENTNAME" 2>/dev/null; then
  tmux new-session -ds "$TMUXCLIENTNAME" -c "$SELECTED"
  tmux set-option -t "$TMUXCLIENTNAME" @stubbe_has_git 1
fi

if [[ -n $TMUX ]]; then
  tmux switch-client -t "$TMUXCLIENTNAME"
else
  tmux attach-session -t "$TMUXCLIENTNAME"
fi
