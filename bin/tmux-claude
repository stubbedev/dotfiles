#!/usr/bin/env zsh

if ! command -v claude &>/dev/null; then
  exit 0
fi

inline=0
if [[ "$1" == "--inline" ]]; then
  inline=1
  shift
fi

if [[ -z "$TMUX" || $inline -eq 1 ]]; then
  claude --dangerously-skip-permissions "$@"
else
  tmux renamew "claude"
  claude --dangerously-skip-permissions "$@"
  tmux kill-pane || exit 0
fi
