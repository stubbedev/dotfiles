#!/usr/bin/env zsh

function toggle_claude {
  if command -v claude &>/dev/null; then
    if [[ -z "$TMUX" ]]; then
      claude
    else
      tmux renamew "claude"
      claude
      CLAUDE_ALIVE=""
      local CLAUDE_ALIVE
      if [[ -z "${CLAUDE_ALIVE}" ]]; then
        tmux kill-pane || exit 0
      fi
    fi
  else
    exit 0
  fi
}

toggle_claude
