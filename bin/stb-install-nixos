#!/usr/bin/env bash
set -euo pipefail

# stb-install-nixos — live-ISO installer for stubbe NixOS hosts.
#
# Detects fixed disks attached to the live system, prompts to pick which
# disks to wipe, formats them as ONE multi-device btrfs volume labeled
# `stubbe`, lays down the subvolume structure that
# modules/nixos/filesystems.nix expects, runs `nixos-install` against
# /etc/nixos/dotfiles#<host>, replaces the read-only
# /etc/nixos/dotfiles store-path with a writable git checkout owned by
# the primary user, and prompts for that user's password.
#
# Run as root from a tty in the live ISO.
#
# Flags:
#   --host  <attr>   nixosConfigurations attribute to install
#                    (default: stubbe-nixos)
#   --flake <path>   Flake to install from
#                    (default: /etc/nixos/dotfiles)
#   --no-reboot      Skip the post-install reboot prompt
#   -h, --help       Show this message

usage() {
  sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'
}

REPO_URL="git@github.com:stubbedev/dotfiles.git"
FLAKE_PATH="/etc/nixos/dotfiles"
FLAKE_ATTR="stubbe-nixos"
PRIMARY_USER="stubbe"
SKIP_REBOOT=0

while [ $# -gt 0 ]; do
  case "$1" in
    --host)      FLAKE_ATTR="${2:?--host requires an argument}"; shift 2 ;;
    --flake)     FLAKE_PATH="${2:?--flake requires an argument}"; shift 2 ;;
    --no-reboot) SKIP_REBOOT=1; shift ;;
    -h|--help)   usage; exit 0 ;;
    *)           echo "stb-install-nixos: unknown argument: $1" >&2; usage >&2; exit 1 ;;
  esac
done

if [ "$(id -u)" -ne 0 ]; then
  echo "stb-install-nixos: must run as root" >&2
  exit 1
fi

# Tee full transcript to a log file so the user can scroll back through
# nixos-install's output after it scrolls off the tty (the live ISO has
# no scrollback in framebuffer mode) and so a failed install leaves an
# artifact to share for debugging.
LOG="/tmp/stb-install-$(date +%Y%m%d-%H%M%S).log"
exec > >(tee "$LOG") 2>&1
echo "stb-install-nixos: transcript -> $LOG"

require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "stb-install-nixos: missing $1 in PATH" >&2
    exit 1
  }
}

require lsblk
require sgdisk
require wipefs
require blkdiscard
require mkfs.btrfs
require mkfs.vfat
require nixos-install
require nixos-enter
require findmnt
require udevadm
require partprobe
require git
require timedatectl

cleanup() {
  # Best-effort unmount on failure so the live system isn't left holding
  # locks on /mnt that block a retry.
  if mountpoint -q /mnt 2>/dev/null; then
    umount -R /mnt 2>/dev/null || true
  fi
}
trap cleanup EXIT

if mountpoint -q /mnt 2>/dev/null; then
  echo "stb-install-nixos: /mnt is already mounted; run 'umount -R /mnt' first" >&2
  exit 1
fi

# --- Network preflight ------------------------------------------------
#
# nixos-install pulls from cache.nixos.org. With no default route it
# fails late with cryptic curl(6) errors after a full evaluation pass.
# Detect early; if missing, hand the user impala so they can join WiFi
# before we burn time on partitioning.
echo "==> Checking network"
if ! ip -4 route show default 2>/dev/null | grep -q .; then
  echo "No default route. Launching impala (WiFi picker)."
  echo "Connect to a network, quit impala, then we'll continue."
  if command -v impala >/dev/null; then
    impala || true
  else
    echo "stb-install-nixos: impala not installed; configure networking manually" >&2
  fi
  if ! ip -4 route show default 2>/dev/null | grep -q .; then
    echo "stb-install-nixos: still no default route, aborting" >&2
    exit 1
  fi
fi

# Cache hits and TLS to cache.nixos.org both require a sane clock. Live
# RTCs on machines that sat in a drawer can be years off; nudge NTP
# before nixos-install rather than chasing a 'certificate not yet valid'
# error mid-install.
echo "==> Syncing clock (NTP)"
timedatectl set-ntp true 2>/dev/null || true
systemctl start systemd-timesyncd 2>/dev/null || true
# Wait briefly for an initial sync; don't block forever — offline mirror
# installs are still possible.
for _ in $(seq 1 20); do
  if timedatectl show -p NTPSynchronized --value 2>/dev/null | grep -q yes; then
    break
  fi
  sleep 0.5
done

# --- Disk discovery + selection --------------------------------------

# Resolve which physical disk hosts the live ISO so we exclude it from
# the wipe set. PKNAME walks lsblk's parent-of relation, which works for
# NVMe (/dev/nvme0n1p1 → nvme0n1) and mmc devices where naive trailing-
# digit stripping breaks. Try the common live-ISO mountpoints in order.
detect_live_disk() {
  local mp src parent
  for mp in /iso /run/initramfs/live /nix/.ro-store /; do
    src="$(findmnt -no SOURCE "$mp" 2>/dev/null || true)"
    [ -n "$src" ] && [ -b "$src" ] || continue
    parent="$(lsblk -no PKNAME "$src" 2>/dev/null | head -1)"
    if [ -n "$parent" ]; then
      echo "$parent"
      return
    fi
  done
}

live_disk="$(detect_live_disk || true)"
if [ -z "$live_disk" ]; then
  echo "stb-install-nixos: WARNING — could not detect live ISO disk." >&2
  echo "Relying on the RM=0 filter to exclude the live USB. Verify the" >&2
  echo "candidate list below DOES NOT contain the disk you booted from." >&2
fi

# Eligible install targets: type=disk, non-removable (RM=0), not the live
# disk. The RM=0 filter is a safety net so an unrelated USB stick plugged
# into the box at install time can't be wiped, and also skips the live
# media itself when detect_live_disk fails.
mapfile -t eligible < <(
  lsblk -dno NAME,TYPE,RM \
    | awk -v live="$live_disk" '$2=="disk" && $3=="0" && $1!=live && $1!~/^zram/ { print $1 }'
)

if [ "${#eligible[@]}" -eq 0 ]; then
  echo "stb-install-nixos: no eligible disks found" >&2
  echo "(live disk: '${live_disk:-unknown}', filter: type=disk, RM=0)" >&2
  exit 1
fi

echo ""
echo "Eligible install disks (live USB '${live_disk:-unknown}' excluded):"
i=0
for d in "${eligible[@]}"; do
  sz=$(lsblk -dno SIZE  "/dev/$d" 2>/dev/null | tr -d ' ')
  model=$(lsblk -dno MODEL "/dev/$d" 2>/dev/null | sed 's/[[:space:]]*$//')
  printf "  [%d] %-12s %-10s %s\n" "$((i+1))" "$d" "$sz" "$model"
  i=$((i+1))
done
echo ""
echo "Pick disks to ERASE and install onto (space-separated indexes, or 'all'."
echo "First selected disk hosts the EFI System Partition; any others join the"
echo "btrfs volume as additional data members.)"
read -r -p "> " selection

# Parse selection into an ordered `candidates` array. Order matters —
# the first entry hosts /boot.
candidates=()
if [ "$selection" = "all" ]; then
  candidates=("${eligible[@]}")
else
  for tok in $selection; do
    [[ "$tok" =~ ^[0-9]+$ ]] || { echo "stb-install-nixos: bad index '$tok'" >&2; exit 1; }
    idx=$((tok - 1))
    if [ "$idx" -lt 0 ] || [ "$idx" -ge "${#eligible[@]}" ]; then
      echo "stb-install-nixos: index $tok out of range" >&2
      exit 1
    fi
    candidates+=("${eligible[$idx]}")
  done
fi
if [ "${#candidates[@]}" -eq 0 ]; then
  echo "stb-install-nixos: no disks selected" >&2
  exit 1
fi

MIN_BYTES=$(( 20 * 1024 * 1024 * 1024 ))
for d in "${candidates[@]}"; do
  sz=$(lsblk -dno SIZE --bytes "/dev/$d" 2>/dev/null || echo 0)
  if (( sz < MIN_BYTES )); then
    echo "stb-install-nixos: /dev/$d is too small ($(( sz / 1024 / 1024 / 1024 )) GiB < 20 GiB minimum)" >&2
    exit 1
  fi
done

# Refuse if any candidate disk has live mounts or md/LUKS/LVM children —
# wipefs would fail mid-loop and leave a partially-wiped state.
for d in "${candidates[@]}"; do
  if findmnt -no SOURCE 2>/dev/null | grep -qE "^/dev/${d}(p?[0-9]+)?\b"; then
    echo "stb-install-nixos: /dev/$d (or its partitions) has an active mount, refusing" >&2
    findmnt | grep -E "^/dev/${d}" >&2 || true
    exit 1
  fi
  child_types="$(lsblk -no TYPE "/dev/$d" 2>/dev/null | tail -n +2 | sort -u)"
  if echo "$child_types" | grep -qE '^(raid[0-9]+|crypt|lvm)$'; then
    echo "stb-install-nixos: /dev/$d has md/LUKS/LVM children, refusing" >&2
    lsblk "/dev/$d" >&2 || true
    exit 1
  fi
done

echo ""
echo "Selected for wipe:"
lsblk -dno NAME,SIZE,MODEL "${candidates[@]/#/\/dev\/}"
echo ""
echo "Host:  ${FLAKE_ATTR}"
echo "Flake: ${FLAKE_PATH}"
echo ""
read -r -p "Proceed and ERASE all listed disks? [y/N] " confirm
case "$confirm" in
  y|Y) ;;
  *) echo "Aborted."; exit 0 ;;
esac

# First disk hosts the EFI System Partition; data partition + every other
# disk become members of the btrfs volume.
boot_disk="${candidates[0]}"
boot_dev="/dev/${boot_disk}"

echo ""
echo "==> Wiping ${#candidates[@]} disk(s)"
for d in "${candidates[@]}"; do
  rota=$(lsblk -dno ROTA "/dev/$d" 2>/dev/null | head -1 | tr -d ' ')
  if [ "$rota" = "0" ]; then
    # SSDs: blkdiscard is orders of magnitude faster than overwriting
    # and resets the FTL's wear-leveling state. Best-effort — discard
    # may be refused on some host bridges / hardware-RAID virtual disks.
    echo "  blkdiscard /dev/$d (SSD)"
    blkdiscard -f "/dev/$d" 2>/dev/null \
      || echo "  blkdiscard failed on /dev/$d, falling back to wipefs only" >&2
  fi
  wipefs -a "/dev/$d"
  sgdisk --zap-all "/dev/$d"
done
udevadm settle

echo "==> Partitioning $boot_dev (1G EFI + remainder for btrfs)"
sgdisk \
  --new=1:0:+1G --typecode=1:ef00 --change-name=1:STBBOOT \
  --new=2:0:0   --typecode=2:8300 --change-name=2:stubbe-data \
  "$boot_dev"
partprobe "$boot_dev" \
  || echo "stb-install-nixos: partprobe warned on $boot_dev, continuing after udevadm settle" >&2
udevadm settle

# NVMe / mmc devices use pN partition suffix; SATA / virtio use plain N.
case "$boot_disk" in
  nvme*|mmcblk*) boot_part="${boot_dev}p1"; first_data="${boot_dev}p2" ;;
  *)             boot_part="${boot_dev}1";  first_data="${boot_dev}2"  ;;
esac

# Kernel may take a moment to expose new partition nodes even after
# partprobe + udevadm settle. Poll up to 10 s before giving up.
wait_for_part() {
  local path="$1" i
  for (( i=0; i<40; i++ )); do
    [[ -b "$path" ]] && return 0
    sleep 0.25
  done
  echo "stb-install-nixos: timed out waiting for block device $path" >&2
  return 1
}
wait_for_part "$boot_part"
wait_for_part "$first_data"

extra_data=()
for d in "${candidates[@]:1}"; do
  extra_data+=("/dev/$d")
done

echo "==> mkfs.vfat $boot_part (label STBBOOT)"
mkfs.vfat -F32 -n STBBOOT "$boot_part"

# Single-disk btrfs can't host raid1 metadata, so fall back to dup. With
# 2+ disks raid1 metadata mirrors so losing one disk doesn't trash the
# filesystem header. Data stays `single` to keep capacity = sum of disks.
if [ "${#extra_data[@]}" -eq 0 ]; then
  meta_profile="dup"
else
  meta_profile="raid1"
fi

echo "==> mkfs.btrfs (label stubbe, -d single -m ${meta_profile}) over $first_data ${extra_data[*]:-}"
mkfs.btrfs -f -L stubbe -d single -m "$meta_profile" "$first_data" "${extra_data[@]}"
udevadm settle

echo "==> Creating subvolumes"
mount -o compress=zstd,noatime "$first_data" /mnt
btrfs subvolume create /mnt/@
btrfs subvolume create /mnt/@home
btrfs subvolume create /mnt/@nix
btrfs subvolume create /mnt/@var
btrfs subvolume create /mnt/@persist
# Snapshot @ while it's still empty. modules/nixos/impermanence.nix
# rolls @ back to this snapshot on every boot when host.impermanent is
# true, leaving /etc and /var blank for the activation script to refill.
# Taken now (always) so flipping host.impermanent on later doesn't
# require reinstalling.
btrfs subvolume snapshot -r /mnt/@ /mnt/@-blank
umount /mnt

mount_opts="compress=zstd,noatime"
echo "==> Mounting subvolumes under /mnt"
mount -o "${mount_opts},subvol=@"           "$first_data" /mnt
mkdir -p /mnt/{home,nix,var,persist,boot,etc}
mount -o "${mount_opts},subvol=@home"       "$first_data" /mnt/home
mount -o "${mount_opts},subvol=@nix"        "$first_data" /mnt/nix
mount -o "${mount_opts},subvol=@var"        "$first_data" /mnt/var
mount -o "${mount_opts},subvol=@persist"    "$first_data" /mnt/persist
# fmask/dmask matches modules/nixos/filesystems.nix so the install-time
# mount sees /boot the same way the installed system will.
mount -o fmask=0077,dmask=0077 "$boot_part" /mnt/boot

echo "==> Running nixos-install --flake ${FLAKE_PATH}#${FLAKE_ATTR}"
# --impure so graphics.nix can read /proc/driver/nvidia/version (populated
# by the live ISO when an NVIDIA card is present — see iso.nix kernelModules)
# and enable the nvidia driver in the installed system iff the target has one.
nixos-install --root /mnt --flake "${FLAKE_PATH}#${FLAKE_ATTR}" --no-root-password --impure

# Resolve uid/gid from the installed system — needed for ownership
# regardless of whether the git clone succeeds.
user_uid="$(nixos-enter --root /mnt --command "id -u ${PRIMARY_USER}")"
user_gid="$(nixos-enter --root /mnt --command "id -g ${PRIMARY_USER}")"

# Replace the read-only ${FLAKE_PATH} store path with a live git checkout so
# `nixos-rebuild switch --flake ${FLAKE_PATH}#...` works after first boot.
# Non-fatal: a network outage or missing SSH key shouldn't brick an
# otherwise complete install. The user can re-clone after first boot.
clone_ok=false
echo "==> Cloning ${REPO_URL} into /mnt${FLAKE_PATH}"
mkdir -p "/mnt$(dirname "${FLAKE_PATH}")"
rm -rf "/mnt${FLAKE_PATH}"
if GIT_SSH_COMMAND="ssh -o StrictHostKeyChecking=accept-new" \
    git clone "$REPO_URL" "/mnt${FLAKE_PATH}"; then
  clone_ok=true
  chown -R "${user_uid}:${user_gid}" "/mnt${FLAKE_PATH}"
else
  echo "" >&2
  echo "WARNING: git clone failed (no network, or SSH key not authorized)." >&2
  echo "Install is complete. After first boot, run as root:" >&2
  echo "  mkdir -p $(dirname "${FLAKE_PATH}") && git clone ${REPO_URL} ${FLAKE_PATH}" >&2
  echo "  chown -R ${PRIMARY_USER}:${PRIMARY_USER} ${FLAKE_PATH}" >&2
fi

home_dir="/mnt/home/${PRIMARY_USER}"
mkdir -p "$home_dir"
if [[ "$clone_ok" == true ]]; then
  ln -sfn "${FLAKE_PATH}" "${home_dir}/.stubbe"
  chown -h "${user_uid}:${user_gid}" "${home_dir}/.stubbe"
fi
chown "${user_uid}:${user_gid}" "$home_dir"

# Copy the user's SSH keys from /root/.ssh (where modules/installer/iso.nix
# baked them on the live ISO) into the installed user's home. Required
# for: git push/pull on the ${FLAKE_PATH} clone, sops-nix decryption at HM
# activation (modules/sops.nix reads ~/.ssh/id_ed25519 to derive an age
# identity), and general SSH access from the new machine. cp -a preserves
# the 0600/0644 modes the tmpfiles rule set.
if [ -d /root/.ssh ]; then
  echo "==> Copying /root/.ssh → ${home_dir}/.ssh"
  ssh_dst="${home_dir}/.ssh"
  mkdir -p "$ssh_dst"
  cp -a /root/.ssh/. "$ssh_dst"/
  chown -R "${user_uid}:${user_gid}" "$ssh_dst"
  chmod 700 "$ssh_dst"
fi

# Secure Boot first-boot hint. lanzaboote requires sbctl keys generated
# and enrolled into firmware before signed boot works. We detect by
# probing for sbctl in the installed system; auto-enrolling is risky
# (some firmware refuses to revert) so we generate keys but leave
# enrollment to the user on first boot.
if nixos-enter --root /mnt -c 'command -v sbctl' >/dev/null 2>&1; then
  if ! nixos-enter --root /mnt -c '[ -d /var/lib/sbctl/keys ]' 2>/dev/null; then
    echo "==> Generating Secure Boot keys (sbctl create-keys)"
    nixos-enter --root /mnt -c 'sbctl create-keys' || \
      echo "  sbctl create-keys failed; generate manually after first boot" >&2
  fi
  echo ""
  echo "Secure Boot: keys are in /var/lib/sbctl. On first boot, put firmware"
  echo "in Setup Mode (clear platform keys in BIOS), then run:"
  echo "  sudo sbctl enroll-keys --microsoft"
  echo "  sudo sbctl verify"
fi

# nixos-install ran with --no-root-password and modules/nixos/users.nix
# doesn't set a password for the primary user, so without this prompt
# the installed system has no console login.
echo ""
echo "==> Set password for ${PRIMARY_USER}"
nixos-enter --root /mnt -c "passwd ${PRIMARY_USER}"

sync
trap - EXIT

echo ""
echo "Install complete."
echo "  Flake checkout: ${FLAKE_PATH} (clone of ${REPO_URL}, owned by ${PRIMARY_USER})"
echo "  Transcript: ${LOG}"
echo "  Log in as '${PRIMARY_USER}', then iterate via:"
echo "    sudo nixos-rebuild switch --flake ${FLAKE_PATH}#${FLAKE_ATTR} --impure"
echo ""

if [ "$SKIP_REBOOT" -ne 1 ]; then
  read -r -p "Reboot now? [y/N] " r
  case "$r" in
    y|Y) echo "Rebooting…"; sync; reboot ;;
    *)   echo "Skipping reboot. Run 'reboot' when ready." ;;
  esac
fi
