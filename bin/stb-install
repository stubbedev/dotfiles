#!/usr/bin/env bash
set -euo pipefail

# stb-install — bootstrap script for non-NixOS hosts.
#
# Steps:
#   1. Symlink ${HOME}/.stubbe to this repo (the rest of the config assumes it).
#   2. Install lix (nix) if missing.
#   3. Configure /etc/nix/nix.conf for flakes + this user as trusted.
#   4. Bootstrap home-manager and run `home-manager switch` against the
#      flake at ${HOME}/.stubbe#stubbe.
#
# Everything else (fonts, docker, dev tools, IDE licenses, ...) is owned
# by home-manager modules under modules/ — don't add it here.

is_root() {
  [ "$(id -u)" -eq 0 ]
}

is_nixos() {
  grep -q '^ID=nixos' /etc/os-release 2>/dev/null
}

main() {
  echo "STUBBEDEV DOTFILES INSTALLER"

  if is_root; then
    echo "Do not run this with sudo. Run it as your user; sudo is requested per-step." >&2
    exit 1
  fi

  if is_nixos; then
    echo "This installer targets non-NixOS hosts. On NixOS, build the flake directly:" >&2
    echo "  nixos-rebuild switch --flake \"$PWD#<host>\"" >&2
    exit 1
  fi

  read -rp "Bootstrap home-manager from this repo? [y/N] " reply
  case "$reply" in
    y | Y) ;;
    *)
      echo "Cancelling."
      exit 0
      ;;
  esac

  link_dotfiles
  install_nix
  configure_nix
  install_home_manager
  switch_home_manager
}

link_dotfiles() {
  if [ -L "$HOME/.stubbe" ] && [ "$(readlink -f "$HOME/.stubbe")" = "$PWD" ]; then
    return 0
  fi
  rm -rf "$HOME/.stubbe"
  ln -sf "$PWD" "$HOME/.stubbe"
}

install_nix() {
  # The lix installer is idempotent: a fresh run on an existing install
  # upgrades it in place. Run unconditionally so every `stb-install` also
  # picks up the latest lix.
  curl -sSf -L https://install.lix.systems/lix | sh -s -- install
}

configure_nix() {
  local conf="/etc/nix/nix.conf"
  local tmpfile original_perms needs_update=false
  tmpfile=$(mktemp)
  trap 'rm -f "$tmpfile"' RETURN
  original_perms=$(stat -c '%a' "$conf")
  cp -f "$conf" "$tmpfile"

  # Settings the flake-based setup depends on. trusted-users lets this user
  # add substituters / use the daemon. keep-outputs/keep-derivations stop GC
  # from evicting build inputs the dev workflow keeps re-using.
  ensure_setting() {
    local key="$1" line="$2"
    if ! grep -Fxq "$line" "$tmpfile"; then
      sed -i "/^${key}/d" "$tmpfile"
      printf '%s\n' "$line" >> "$tmpfile"
      needs_update=true
    fi
  }

  ensure_setting "experimental-features" "experimental-features = nix-command flakes"
  ensure_setting "trusted-users"         "trusted-users = root $USER"
  ensure_setting "sandbox"               "sandbox = relaxed"
  ensure_setting "keep-outputs"          "keep-outputs = true"
  ensure_setting "keep-derivations"      "keep-derivations = true"

  if [ "$needs_update" = true ]; then
    sudo cp -f "$tmpfile" "$conf"
    sudo chmod "$original_perms" "$conf"
  fi
}

install_home_manager() {
  if [ -x "$HOME/.nix-profile/bin/home-manager" ]; then
    return 0
  fi
  export NIXPKGS_ALLOW_UNFREE=1
  /nix/var/nix/profiles/default/bin/nix-channel --add \
    https://github.com/nix-community/home-manager/archive/master.tar.gz home-manager
  /nix/var/nix/profiles/default/bin/nix-channel --update
  /nix/var/nix/profiles/default/bin/nix-shell '<home-manager>' -A install
}

switch_home_manager() {
  local flake_path
  flake_path=$(readlink -f "$HOME/.stubbe")
  "$HOME/.nix-profile/bin/home-manager" switch --impure --flake "$flake_path#stubbe"
}

main "$@"
