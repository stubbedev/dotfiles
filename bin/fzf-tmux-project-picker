#!/usr/bin/env zsh

SELECTED=$(fzf-project-picker-util "$*")

if [[ -z $SELECTED ]]; then
  exit 0
fi

SELECTED_NAME=$(basename "$SELECTED" | tr '.' '_')
TMUXCLIENTNAME="$(whoami)($SELECTED_NAME)"
TMUX_RUNNING=$(pgrep tmux)

if [[ -z $TMUX ]] && [[ -z $TMUX_RUNNING ]]; then
  tmux new-session -ds "$TMUXCLIENTNAME" -c "$SELECTED"
fi

if ! tmux has-session -t="$TMUXCLIENTNAME" 2>/dev/null; then
  tmux new-session -ds "$TMUXCLIENTNAME" -c "$SELECTED"
  tmux set-option -t "$TMUXCLIENTNAME" @stubbe_has_git 1
fi

# switch-client errors "no current client" when $TMUX is set but the client
# has detached (stale env). Fall back to attach in this terminal; clear $TMUX
# so tmux doesn't refuse the nested attach.
tmux switch-client -t "$TMUXCLIENTNAME" 2>/dev/null \
  || TMUX= tmux attach-session -t "$TMUXCLIENTNAME"
