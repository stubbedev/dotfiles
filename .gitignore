bin/nvim
src/nvim/lazy-lock.json
src/nvim/lazyvim.json
src/btop/btop.log
src/btop/btop.conf
src/neomutt/accounts/*/*/cache/bodies/*
src/neomutt/accounts/*/*/cache/headers/*
src/neomutt/accounts/*/*/cert/*
src/vpn/*/config

# All files under secrets/ are sops-encrypted (binary mode) and tracked.
# Plaintext drafts that escape into secrets/ at edit time stay in the
# editor's unsaved buffer or in /tmp — sops never writes plaintext to disk
# under secrets/, and there's no extension cue to keep them separate, so
# we trust the workflow rather than try to filter by name.

# Build artifacts from `nix build` and `home-manager build`.
result
result-*

# Local cargo builds (we package via rustPlatform; target/ is throwaway).
src/**/target/

.claude/
