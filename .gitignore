bin/nvim
src/zsh/plugins.d
src/zsh/fpaths.d
src/zsh/history
src/zsh/update_flag
src/zsh/*.zwc
src/nvim/lazy-lock.json
src/nvim/lazyvim.json
src/btop/btop.log
src/btop/btop.conf
src/neomutt/accounts/*/*/password.gpg
src/neomutt/accounts/*/*/cache/bodies/*
src/neomutt/accounts/*/*/cache/headers/*
src/neomutt/accounts/*/*/cert/*
src/aerc/accounts/*/*/password.gpg
src/vpn/*/password.gpg
src/vpn/*/config

# Encrypted secrets under secrets/*.yaml ARE tracked (sops-nix decrypts at
# activation). Anything else under secrets/ — plaintext drafts, intermediate
# files — is not.
secrets/*
!secrets/*.yaml

# Build artifacts from `nix build` and `home-manager build`.
result
result-*

.claude/
